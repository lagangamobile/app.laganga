<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:com.laganga.app"
             xmlns:shared="clr-namespace:com.laganga.app.Shared;assembly=com.laganga.app.Shared"
             x:Class="com.laganga.app.MainPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Padding="0">

    <BlazorWebView x:Name="blazorWebView" 
                   HostPage="wwwroot/index.html"
                   Margin="0">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type shared:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>