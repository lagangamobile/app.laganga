@inherits LayoutComponentBase
@using System.Collections.Generic
@inject com.laganga.app.Shared.Services.LayoutService LayoutService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IDisposable

<div class="card no-border layout-root">
    <div class="card-header no-border p-2 bg-ganga">
        <div class="toolbar-container">
            @if (_isHome)
            {
                <button type="button"
                        class="drawer-toggle-btn"
                        aria-label="@(LayoutService.IsDrawerOpen ? "Cerrar Menú" : "Abrir Menú")"
                        aria-pressed="@LayoutService.IsDrawerOpen.ToString()"
                        @onclick="ToggleInfo">
                    <div class="@($"header__burger {(LayoutService.IsDrawerOpen ? "active" : "")}")">
                        <i></i><i></i><i></i>
                    </div>
                </button>
            }
            else
            {
                <button type="button"
                        class="back-btn"
                        aria-label="Regresar"
                        @onclick="GoBack">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                </button>

                <span class="toolbar-title">@LayoutService.Title</span>

                <button type="button"
                        class="drawer-toggle-btn"
                        aria-label="@(LayoutService.IsDrawerOpen ? "Cerrar Menú" : "Abrir Menú")"
                        aria-pressed="@LayoutService.IsDrawerOpen.ToString()"
                        @onclick="ToggleInfo">
                    <div class="@($"header__burger {(LayoutService.IsDrawerOpen ? "active" : "")}")">
                        <i></i><i></i><i></i>
                    </div>
                </button>
            }
        </div>
    </div>

    <div class="card-body p-0 bg-ganga">
        <div class="drawer-wrapper">
            @* Overlay *@
            @if (LayoutService.IsDrawerOpen)
            {
                <div class="drawer-overlay" @onclick="CloseInfo"></div>
            }

            @* Panel del drawer *@
            <div class="drawer-panel @(LayoutService.IsDrawerOpen ? "open" : "")">
                <NavMenu OnNavigate="CloseInfo" />
            </div>

            @* Contenido principal *@
            <div class="drawer-content">
                <div class="page page-content-wrapper">
                    <main class="main-wrapper">
                        <article class="content px-4 scroll-content page-custom-radius-bg">
                            <com.laganga.app.Shared.Pages.ConnectivityBanner />
                            @Body
                        </article>
                    </main>
                </div>

                <div id="blazor-error-ui" data-nosnippet>
                    An unhandled error has occurred.
                    <a href="." class="reload">Reload</a>
                    <span class="dismiss">🗙</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; }

    private bool _isHome;
    private IDisposable? _locReg;

    protected override void OnInitialized()
    {
        LayoutService.DrawerStateChanged += OnDrawerStateChanged;
        LayoutService.StateChanged += OnLayoutStateChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
        EvaluateRoute(NavigationManager.Uri);
    }

    void OnDrawerStateChanged() => InvokeAsync(StateHasChanged);

    void OnLayoutStateChanged() => InvokeAsync(StateHasChanged);

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        EvaluateRoute(e.Location);
        InvokeAsync(StateHasChanged);
    }

    void EvaluateRoute(string uri)
    {
        var relative = NavigationManager.ToBaseRelativePath(uri).TrimEnd('/');
        _isHome = string.IsNullOrEmpty(relative);
    }

    void ToggleInfo() => LayoutService.ToggleDrawer();

    void CloseInfo() => LayoutService.CloseDrawer();

    async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    public void Dispose()
    {
        LayoutService.DrawerStateChanged -= OnDrawerStateChanged;
        LayoutService.StateChanged -= OnLayoutStateChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        _locReg?.Dispose();
    }
}

<style>

    :root {
        --drawer-width: 225px;
    }

    .bg-ganga {
        background: var(--color-primary);
    }

    .page-custom-radius-bg {
        border-radius: 15px 15px 0px 0px;
        background: var(--bg-light);
    }

    @@media (prefers-color-scheme: dark) {
        .page-custom-radius-bg {
            background: var(--bg-dark);
        }
    }

    .layout-root {
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

        .layout-root > .card-body {
            flex: 1;
            display: flex;
            min-height: 0;
        }

    /* Toolbar */
    .toolbar-container {
        display: flex;
        align-items: center;
        padding: 0;
        gap: .5rem;
    }

    .drawer-toggle-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.3rem;
        outline: none;
        margin-left: auto;
    }

        .drawer-toggle-btn:focus-visible {
            outline: 2px solid var(--color-secondary);
            outline-offset: 2px;
            border-radius: 4px;
        }

    .back-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.3rem;
        color: #fff;
        display: inline-flex;
        align-items: center;
        outline: none;
    }

        .back-btn:focus-visible {
            outline: 2px solid var(--color-secondary);
            outline-offset: 2px;
            border-radius: 4px;
        }

    .toolbar-title {
        color: #fff;
        font-size: .9rem;
        font-weight: 600;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Drawer wrapper */
    .drawer-wrapper {
        display: flex;
        width: 100%;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

    /* Overlay */
    .drawer-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 50;
        transition: opacity 0.3s ease;
    }

    /* Drawer panel */
    .drawer-panel {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: var(--drawer-width);
        background: var(--bg-light);
        z-index: 60;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow-y: auto;
        box-shadow: -4px 0 16px rgba(0, 0, 0, 0.15);
    }

        .drawer-panel.open {
            transform: translateX(0);
        }

    @@media (prefers-color-scheme: dark) {
        .drawer-panel {
            background: #161b22;
            box-shadow: -4px 0 16px rgba(0, 0, 0, 0.4);
        }
    }

    /* Drawer content */
    .drawer-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        height: 100%;
    }

    .page-content-wrapper,
    .main-wrapper {
        height: 100%;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .main-wrapper {
        flex: 1;
        min-height: 0;
    }

    .scroll-content {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
    }

    @@media (max-width: 600px) {
        .scroll-content {
            padding-left: 1rem;
            padding-right: 1rem;
        }
    }

    /* Burger icon */
    .header__burger {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 4px;
        width: 24px;
        margin-top: .3rem;
        margin-bottom: .3rem;
    }

        .header__burger i {
            width: 100%;
            height: 2px;
            background-color: #fff;
            border-radius: 13px;
            transition: 0.4s;
        }

        .header__burger.active i:nth-child(1) {
            transform: rotate(45deg) translate(4px, 4px);
        }

        .header__burger.active i:nth-child(2) {
            opacity: 0;
        }

        .header__burger.active i:nth-child(3) {
            transform: rotate(-45deg) translate(4px, -5px);
        }

    .no-border {
        border: 0 !important;
        border-radius: unset !important;
    }
</style>