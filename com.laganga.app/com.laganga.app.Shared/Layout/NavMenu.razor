@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@using System.Collections.Generic
@inject IAuthenticationService AuthService
@inject IApiGangaClient ApiClient
@inject NavigationManager NavigationManager
@inject IFormFactor FormFactor
@implements IDisposable

<div class="nav-menu-container">
    <div class="nav-menu-header">
        <span class="nav-menu-title">@CurrentUserDisplayName</span>
    </div>

    <nav class="nav-menu-body" aria-label="Menú principal">
        @if (isLoading)
        {
            <div class="nav-menu-loading">
                <div class="nav-spinner"></div>
                <span>Cargando menú…</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(loadError))
        {
            <div class="nav-menu-error">
                <span>@loadError</span>
                <button type="button" class="nav-retry-btn" @onclick="LoadMenuAsync">Reintentar</button>
            </div>
        }
        else
        {
            <ul class="nav-menu-list">
                @foreach (var item in menuItems.Where(i => i.Visible).OrderBy(i => i.Orden))
                {
                    @if (item.Hijos.Any(h => h.Visible))
                    {
                        <li class="nav-menu-group">
                            <button type="button"
                                    class="nav-menu-link nav-menu-toggle @(IsGroupExpanded(item.Id) ? "expanded" : "")"
                                    @onclick="() => ToggleGroup(item.Id)">
                                @if (!string.IsNullOrEmpty(item.Icono))
                                {
                                    <i class="@item.Icono nav-menu-icon"></i>
                                }
                                <span>@item.Nombre</span>
                                <svg class="nav-chevron" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                                    <path d="M7 10l5 5 5-5z" />
                                </svg>
                            </button>
                            @if (IsGroupExpanded(item.Id))
                            {
                                <ul class="nav-submenu">
                                    @foreach (var child in item.Hijos.Where(h => h.Visible).OrderBy(h => h.Orden))
                                    {
                                        <li>
                                            <a class="nav-menu-link nav-submenu-link @(IsActive(child.Ruta) ? "active" : "")"
                                               href="@child.Ruta"
                                               @onclick="() => OnMenuItemClick(child.Ruta)">
                                                @if (!string.IsNullOrEmpty(child.Icono))
                                                {
                                                    <i class="@child.Icono nav-menu-icon"></i>
                                                }
                                                <span>@child.Nombre</span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                    else
                    {
                        <li>
                            <a class="nav-menu-link @(IsActive(item.Ruta) ? "active" : "")"
                               href="@item.Ruta"
                               @onclick="() => OnMenuItemClick(item.Ruta)">
                                @if (!string.IsNullOrEmpty(item.Icono))
                                {
                                    <i class="@item.Icono nav-menu-icon"></i>
                                }
                                <span>@item.Nombre</span>
                            </a>
                        </li>
                    }
                }
            </ul>
        }
    </nav>

    <div class="nav-menu-bottom">
        <button type="button" class="nav-menu-link nav-logout-btn" @onclick="HandleLogout">
            <i class="bi bi-box-arrow-right nav-menu-icon"></i>
            <span>Cerrar Sesión</span>
        </button>
        <div class="nav-menu-footer">
            <span>v@(FormFactor.GetVersion())</span>
        </div>
    </div>
</div>

<style>
    .nav-menu-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    }

    .nav-menu-header {
        padding: 1rem 1rem 0.75rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .nav-menu-title {
        font-size: 1rem;
        font-weight: 700;
        color: #000064;
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nav-menu-body {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem 0;
    }

    .nav-menu-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-menu-link {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        padding: 0.7rem 1rem;
        border: none;
        background: transparent;
        color: #334155;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        text-align: left;
    }

        .nav-menu-link:hover {
            background: rgba(91, 208, 239, 0.08);
            color: #000064;
        }

        .nav-menu-link.active {
            background: rgba(91, 208, 239, 0.12);
            color: #000064;
            font-weight: 600;
            border-right: 3px solid #5bd0ef;
        }

    .nav-menu-icon {
        font-size: 1.1rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
        color: #64748b;
    }

    .nav-menu-link:hover .nav-menu-icon,
    .nav-menu-link.active .nav-menu-icon {
        color: #5bd0ef;
    }

    /* Toggle / Chevron */
    .nav-menu-toggle {
        justify-content: flex-start;
    }

    .nav-chevron {
        margin-left: auto;
        transition: transform 0.25s ease;
        color: #94a3b8;
        flex-shrink: 0;
    }

    .nav-menu-toggle.expanded .nav-chevron {
        transform: rotate(180deg);
    }

    /* Submenu */
    .nav-submenu {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-submenu-link {
        padding-left: 2.5rem;
        font-size: 0.825rem;
    }

    /* Group */
    .nav-menu-group {
        border-bottom: 1px solid #f1f5f9;
    }

    /* Loading & Error */
    .nav-menu-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 2rem 1rem;
        color: #94a3b8;
        font-size: 0.8rem;
    }

    .nav-spinner {
        width: 24px;
        height: 24px;
        border: 2px solid #e2e8f0;
        border-top-color: #5bd0ef;
        border-radius: 50%;
        animation: nav-spin 0.8s linear infinite;
    }

    @@keyframes nav-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .nav-menu-error {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1.5rem 1rem;
        color: #dc3545;
        font-size: 0.8rem;
        text-align: center;
    }

    .nav-retry-btn {
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        border: 1px solid #0d6efd;
        background: #0d6efd;
        color: #fff;
        cursor: pointer;
        font-size: 0.75rem;
    }

        .nav-retry-btn:hover {
            background: #0a58ca;
        }

    /* Bottom section */
    .nav-menu-bottom {
        margin-top: auto;
        border-top: 1px solid #e2e8f0;
    }

    .nav-logout-btn {
        color: #dc3545;
        font-weight: 600;
    }

        .nav-logout-btn .nav-menu-icon {
            color: #dc3545;
        }

        .nav-logout-btn:hover {
            background: rgba(220, 53, 69, 0.08);
            color: #b02a37;
        }

            .nav-logout-btn:hover .nav-menu-icon {
                color: #b02a37;
            }

    .nav-menu-footer {
        text-align: center;
        padding: 0.5rem 0.5rem 0.75rem;
        font-size: 0.65rem;
        color: #9ca3af;
    }

    /* Dark mode */
    @@media (prefers-color-scheme: dark) {
        .nav-menu-header {
            border-bottom-color: #30363d;
        }

        .nav-menu-title {
            color: #5bd0ef;
        }

        .nav-menu-link {
            color: #c9d1d9;
        }

            .nav-menu-link:hover {
                background: rgba(91, 208, 239, 0.08);
                color: #f0f6fc;
            }

            .nav-menu-link.active {
                background: rgba(91, 208, 239, 0.12);
                color: #5bd0ef;
                border-right-color: #5bd0ef;
            }

        .nav-menu-icon {
            color: #8b949e;
        }

        .nav-menu-link:hover .nav-menu-icon,
        .nav-menu-link.active .nav-menu-icon {
            color: #5bd0ef;
        }

        .nav-chevron {
            color: #6e7681;
        }

        .nav-menu-group {
            border-bottom-color: #21262d;
        }

        .nav-menu-bottom {
            border-top-color: #30363d;
        }

        .nav-logout-btn {
            color: #f85149;
        }

            .nav-logout-btn .nav-menu-icon {
                color: #f85149;
            }

            .nav-logout-btn:hover {
                background: rgba(248, 81, 73, 0.1);
                color: #ff7b72;
            }

                .nav-logout-btn:hover .nav-menu-icon {
                    color: #ff7b72;
                }

        .nav-menu-footer {
            color: #6b7280;
        }

        .nav-spinner {
            border-color: #30363d;
            border-top-color: #5bd0ef;
        }
    }
</style>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }

    private List<MenuItem> menuItems = new();
    private HashSet<int> expandedGroups = new();
    private bool isLoading;
    private string? loadError;
    private CancellationTokenSource? _cts;

    private string CurrentUserDisplayName => GetUserDisplayName();

    protected override void OnInitialized()
    {
        AuthService.AuthenticationStateChanged += OnAuthenticationStateChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (AuthService.IsAuthenticated)
            {
                await AuthService.EnsureClaimsLoadedAsync();
            }

            await LoadMenuAsync();
        }
    }

    private async Task LoadMenuAsync()
    {
        loadError = null;
        isLoading = true;
        StateHasChanged();

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        try
        {
            var response = await ApiClient.GetAsync<List<MenuItem>>("v1/configuracion/initialize", ct);

            if (response?.succeeded == true && response.data is not null)
            {
                menuItems = response.data;
            }
            else
            {
                loadError = response?.message ?? "No se pudo cargar el menú.";
                menuItems = new();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            loadError = $"Error: {ex.Message}";
            menuItems = new();
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetUserDisplayName()
    {
        var user = AuthService.CurrentUser;
        if (user == null) return "La Ganga";

        var nickname = user.FindFirst("nickname")?.Value;
        if (!string.IsNullOrEmpty(nickname)) return nickname;

        var givenName = user.FindFirst("given_name")?.Value;
        if (!string.IsNullOrEmpty(givenName)) return givenName;

        var name = user.FindFirst("name")?.Value;
        if (!string.IsNullOrEmpty(name)) return name;

        return user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "La Ganga";
    }

    private void OnAuthenticationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleGroup(int id)
    {
        if (!expandedGroups.Remove(id))
            expandedGroups.Add(id);
    }

    private bool IsGroupExpanded(int id) => expandedGroups.Contains(id);

    private bool IsActive(string? ruta)
    {
        if (string.IsNullOrEmpty(ruta)) return false;
        var currentUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var menuPath = ruta.TrimStart('/');
        return string.Equals(currentUri, menuPath, StringComparison.OrdinalIgnoreCase)
            || currentUri.StartsWith(menuPath + "?", StringComparison.OrdinalIgnoreCase)
            || currentUri.StartsWith(menuPath + "/", StringComparison.OrdinalIgnoreCase);
    }

    private void OnMenuItemClick(string? ruta)
    {
        if (!string.IsNullOrEmpty(ruta) && OnNavigate.HasDelegate)
        {
            OnNavigate.InvokeAsync();
        }
    }

    private async void HandleLogout()
    {
        await AuthService.LogoutAsync();
        if (OnNavigate.HasDelegate)
            await OnNavigate.InvokeAsync();
        NavigationManager.NavigateTo("/loginU", replace: true);
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        try { _cts?.Cancel(); } catch (ObjectDisposedException) { }
        _cts?.Dispose();
        _cts = null;
    }
}