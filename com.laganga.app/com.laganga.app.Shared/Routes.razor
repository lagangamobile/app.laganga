@using Microsoft.AspNetCore.Components.Routing
@using com.laganga.app.Shared.Services
@inject IAuthenticationService AuthService
@inject NavigationManager NavigationManager
@inject LayoutService LayoutService
@DxResourceManager.RegisterTheme(Themes.Fluent)
@implements IDisposable

@if (!_isReady)
{
    <!-- Pantalla de carga mientras se inicializa la autenticación -->
    <div class="auth-loading-screen">
        <div class="auth-loading-content">
            <div class="auth-loader-ring"></div>
        </div>
    </div>
}
else
{
    <Router AppAssembly="typeof(Layout.MainLayout).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
}

<style>
    .auth-loading-screen {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #000064;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .auth-loading-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    @@keyframes auth-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .auth-loader-ring {
        border: 4px solid #5bd0ef;
        border-top-color: #ffffff;
        border-radius: 50%;
        width: 56px;
        height: 56px;
        animation: auth-spin 1s linear infinite;
    }
</style>

@code {
    private IDisposable? _navReg;
    private bool _isReady;

    protected override async Task OnInitializedAsync()
    {
        // Esperar a que el servicio de autenticación termine de inicializarse
        await AuthService.WaitForInitializationAsync();
        
        _isReady = true;
        
        // Registrar handlers después de la inicialización
        _navReg = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
        AuthService.AuthenticationStateChanged += OnAuthenticationStateChanged;
        
        // Realizar la redirección inicial basada en el estado de autenticación
        HandleAuthenticationRedirect();
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        LayoutService.CloseDrawer();

        var target = context.TargetLocation;

        if (!AuthService.IsAuthenticated && !IsLoginUri(target))
        {
            context.PreventNavigation();
            NavigationManager.NavigateTo("/loginU", replace: true);
            return;
        }

        if (AuthService.IsAuthenticated && IsLoginUri(target))
        {
            context.PreventNavigation();
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await Task.CompletedTask;
    }

    private static bool IsLoginUri(string target)
    {
        if (!Uri.TryCreate(target, UriKind.Absolute, out var uri))
            return target.EndsWith("/loginU", StringComparison.OrdinalIgnoreCase);

        var path = uri.AbsolutePath.TrimEnd('/');
        return path.Equals("/loginU", StringComparison.OrdinalIgnoreCase);
    }

    private void HandleAuthenticationRedirect()
    {
        if (AuthService.IsAuthenticated)
        {
            if (IsLoginUri(NavigationManager.Uri))
                NavigationManager.NavigateTo("/", replace: true);
        }
        else
        {
            if (!IsLoginUri(NavigationManager.Uri))
                NavigationManager.NavigateTo("/loginU", replace: true);
        }
    }

    private void OnAuthenticationStateChanged()
    {
        InvokeAsync(() =>
        {
            HandleAuthenticationRedirect();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        _navReg?.Dispose();
    }
}