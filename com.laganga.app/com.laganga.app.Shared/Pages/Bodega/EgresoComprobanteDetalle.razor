@page "/Bodega/EgresoComprobanteDetalle/{guid}"
@using System.Net.Http.Json
@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@using DevExpress.Blazor
@inject IHttpClientFactory HttpClientFactory
@inject IAuthenticationService AuthService
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject NavigationManager Nav
@inject IJSRuntime JS


@if (isLoading)
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block info">Cargando información...</div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block error">@loadError</div>
}
else if (item == null)
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block warn">No se encontró información para la secuencia.</div>
}
else
{
    <h3 class="page-title">@($"Despacho {GetTipoName()}: {item!.IdentificadorOrigenVisible}")</h3>

    <div class="detalle-root">

        <!-- Sentinel para detectar colapso (para sticky) -->
        <div id="stickySentinel" class="sticky-sentinel" aria-hidden="true"></div>

        <!-- Encabezado fijo (se colapsa con clase .compact) -->
        <div class="top-header">
            @* <div class="id-box">
                <label>@($"{GetTipoName()}: {item!.IdentificadorOrigenVisible}")</label>
            </div> *@
            <div class="progress-box">
                <div class="progress-info">
                    <span>Productos: <strong>@TotalProductosIngresados</strong>/<strong>@TotalProductos</strong></span>
                    <span class="small muted">(@ProgressPercent.ToString("0")%)</span>
                </div>
                <div class="progress-bar-outer">
                    <div class="progress-bar-inner" style="width:@($"{ProgressPercent}%")"></div>
                </div>
            </div>
            <div class="actions-inline">
                <DxButton Text="Regresar"
                          ButtonType="ButtonType.Normal"
                          Click='() => Nav.NavigateTo("/Bodega/EgresoComprobante", true)' />
                <DxButton Text="Finalizar"
                          CssClass="finalize"
                          Enabled="@CanFinalize()"
                          Click="() => showFinalizeConfirm = true" />
            </div>
        </div>

        <!-- Comprobantes: tarjetas horizontales (sticky bajo el header) -->
        <div class="comprobantes-wrapper">
            <div class="comprobantes-strip" role="tablist" aria-label="Comprobantes">
                @foreach (var key in groupKeys)
                {
                    var comp = groupedComprobantes[key].First();
                    var (cap, exp) = GetCompProgress(key);
                    <button type="button"
                            class="comp-card @(selectedCompte == key ? "selected" : "")"
                            role="tab"
                            aria-selected="@(selectedCompte == key ? "true" : "false")"
                            @onclick="() => SeleccionarCompte(key)">
                        <div class="comp-row">
                            <div class="comp-num">#@comp.NumCompte</div>
                            <div class="comp-bod">@($"Bod: {comp.Bodega}")</div>
                        </div>
                        @* <div class="comp-row">
                            <div class="comp-date">@comp.Fecha:dd/MM/yyyy</div>
                        </div> *@
                        <div class="comp-progress">
                            <div class="rail">
                                <div class="fill" style="width:@(exp == 0 ? "0%" : $"{Math.Min(100, (int)((double)cap / exp * 100))}%")"></div>
                            </div>
                            <div class="meta">@cap/@exp</div>
                        </div>
                        @if (selectedCompte == key)
                        {
                            <div class="chip-current">En captura</div>
                        }
                    </button>
                }
            </div>
        </div>

        <!-- Banner de comprobante seleccionado -->
        @if (!string.IsNullOrWhiteSpace(selectedCompte) && 1 == 0)
        {
            <div class="selected-comp-banner">
                <span class="label">Comprobante seleccionado:</span>
                <span class="value">NumCompte: @selectedNumCompte • Bodega: @selectedBodega</span>
            </div>
        }

        <!-- Grid de detalles del comprobante seleccionado -->
        @{
            var compSel = (!string.IsNullOrWhiteSpace(selectedCompte) && groupedComprobantes.TryGetValue(selectedCompte, out var listSel))
            ? listSel.FirstOrDefault()
            : null;
        }
        @if (compSel != null)
        {
            <details class="accordion-panel" id="detallesAccordion">
                <summary class="accordion-summary">
                    Detalles del comprobante (@(compSel.Detalles?.Sum(d => d.CantidadIngresada) ?? 0)/@(compSel.Detalles?.Sum(d => d.Cantidad) ?? 0))
                </summary>
                <div class="accordion-content">
                    <DxGrid Data="compSel.Detalles"
                            T="DetalleMovimiento"
                            ShowFilterRow="false"
                            ShowGroupPanel="false"
                            ShowPager="false"
                            KeyboardNavigationEnabled="true"
                            RowClick="OnDetalleRowClick"
                            CssClass="detalles-grid"
                            ColumnResizeMode="GridColumnResizeMode.Disabled"
                            SizeMode="SizeMode.Small"
                            PageSize="5">
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(DetalleMovimiento.CodigoItem)" Caption="Artículo" Width="85px" />
                            <DxGridDataColumn FieldName="@nameof(DetalleMovimiento.Descripcion)" Caption="Descripción" />
                            <DxGridDataColumn FieldName="@nameof(DetalleMovimiento.Cantidad)" Caption="Cant" Width="40px" />
                            <DxGridDataColumn FieldName="@nameof(DetalleMovimiento.CantidadIngresada)" Caption="Ing" Width="40px" />
                        </Columns>
                    </DxGrid>
                </div>
            </details>
        }

        <!-- Panel de Captura -->
        <div class="capture-panel">
            <div class="section-title">Captura</div>
            <div class="responsive-grid">
                <DxTextBox LabelText="Código"
                           Id="txtCodigoCaptura"
                           CssClass="@(codigoValido ? "valid" : null)"
                           ValidationEnabled="true"
                           ShowValidationSuccessState="@codigoValido"
                           @ref="txtCodigoCapturaRef"
                           @bind-Text="codigoItemIngresado"
                           InputType="InputType.Text"
                           SizeMode="SizeMode.Small"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                           ReadOnly="false"
                           @onkeydown="HandleCodigoItemCaptura"
                           NullText="Escanear / escribir código">
                </DxTextBox>

                <!-- Artículo: reemplazado por chip compacta -->
                <div class="field-compact" style='@(!codigoValido ? "display: none;" : "")'>
                    @* <div class="field-label">Artículo</div> *@
                    <div class="chip article-chip" title="@articuloDescripcion">
                        @(string.IsNullOrWhiteSpace(articuloDescripcion) ? "—" : articuloDescripcion)
                    </div>
                </div>

                <DxTextBox LabelText="Serie"
                           Id="txtSerieCaptura"
                           @ref="txtSerieCapturaRef"
                           @bind-Text="serieIngresada"
                           InputType="InputType.Text"
                           SizeMode="SizeMode.Small"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                           ReadOnly="false"
                           NullText="Escanear serie"
                           @onkeydown="HandleSerieCaptura" />
            </div>

            <div class="capture-actions">
                <DxButton Text="Ingresar Serie"
                          Enabled="@(selectedDetalle != null && !string.IsNullOrWhiteSpace(serieIngresada))"
                          Click="IngresarSerie" />
                <DxButton Text="Limpiar"
                          ButtonType="ButtonType.Normal"
                          Click="ResetCapturaActual" />
            </div>

            @if (!string.IsNullOrEmpty(productoNoEncontradoMessage))
            {
                <div class="status-inline warn">@productoNoEncontradoMessage</div>
            }

            @if (selectedDetalle != null)
            {
                <div class="series-wrapper">
                    <div class="series-header">
                        Series capturadas (@selectedDetalle.SeriesCapturadas.Count):
                        <span class="small muted">
                            Esperadas: @ExpectedSeriesFor(selectedDetalle)
                        </span>
                    </div>
                    <div class="series-chips">
                        @foreach (var s in selectedDetalle.SeriesCapturadas)
                        {
                            <span class="chip">
                                @s
                                <button type="button" class="chip-remove" @onclick="() => RemoveSerie(s)">×</button>
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        @* <div class="footer-space"></div> *@
    </div>
}

<!-- Popup Finalizar -->
<DxPopup @bind-Visible="showFinalizeConfirm"
         Width="340px"
         CloseOnOutsideClick="true"
         ShowCloseButton="true"
         ShowFooter="false">
    <HeaderTemplate>Confirmar envío</HeaderTemplate>
    <BodyTemplate>
        <div class="confirm-body">
            <p>Se enviará la información capturada. ¿Desea continuar?</p>
            <ul class="mini-list">
                <li>Total productos ingresados: <strong>@TotalProductosIngresados</strong></li>
                <li>Total productos: <strong>@TotalProductos</strong></li>
                <li>Progreso: <strong>@ProgressPercent.ToString("0")%</strong></li>
            </ul>
            @if (!string.IsNullOrEmpty(postError))
            {
                <div class="status-inline error">@postError</div>
            }
            <div class="dialog-actions">
                <DxButton Text="Cancelar" ButtonType="ButtonType.Normal" Enabled="!isPosting" Click="() => showFinalizeConfirm = false" />
                <DxButton Text="Enviar"
                          CssClass="finalize"
                          Enabled="@(CanFinalize() && !isPosting)"
                          Click="FinalizarAsync" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup Éxito -->
<DxPopup @bind-Visible="showSuccess"
         Width="300px"
         CloseOnOutsideClick="false"
         ShowFooter="false">
    <HeaderTemplate>Procesado</HeaderTemplate>
    <BodyTemplate>
        <div class="confirm-body">
            <p>Datos enviados correctamente.</p>
            <div class="dialog-actions">
                <DxButton Text="Aceptar" Click='() => Nav.NavigateTo("/Bodega/EgresoComprobante", true)' />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter] public string guid { get; set; } = string.Empty;

    private DxTextBox? txtCodigoCapturaRef;
    private DxTextBox? txtSerieCapturaRef;

    private bool _pendingInitialFocus;
    private OrigenMovimiento? item;
    private Dictionary<string, List<ComprobanteMovimiento>> groupedComprobantes = new();
    private List<string> groupKeys = new();
    private string selectedCompte = "";
    private string selectedNumCompte = "";
    private string selectedBodega = "";
    private DetalleMovimiento? selectedDetalle;

    private bool isLoading = true;
    private string? loadError;
    private CancellationTokenSource? _cts;

    private string _codigoItemIngresado = "";
    private bool _inReset;

    // [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Debe ingresar Codigo")]
    // [System.ComponentModel.DataAnnotations.StringLength(16, ErrorMessage = "The Identifier exceeds 16 characters.")]
    private string codigoItemIngresado
    {
        get => _codigoItemIngresado;
        set
        {
            var newVal = value ?? string.Empty;
            var wasEmpty = string.IsNullOrEmpty(_codigoItemIngresado);
            _codigoItemIngresado = newVal;

            // Si pasó de tener valor a quedar vacío (p.ej. ClearButton), resetea captura
            if (!_inReset && !wasEmpty && string.IsNullOrEmpty(newVal))
            {
                try
                {
                    _inReset = true;
                    ResetCapturaActual();
                }
                finally
                {
                    _inReset = false;
                }
            }
        }
    }
    private string articuloDescripcion = "";
    private string serieIngresada = "";
    private string productoNoEncontradoMessage = "";

    // NUEVO: Estado visual del código válido
    private bool codigoValido = false;

    // Finalización
    private bool showFinalizeConfirm = false;
    private bool showSuccess = false;
    private bool isPosting = false;
    private string? postError;

    // Métricas (productos)
    private int TotalProductosIngresados =>
        groupedComprobantes.Values
            .SelectMany(c => c)
            .SelectMany(c => c.Detalles)
            .Sum(d => d.CantidadIngresada);

    private int TotalProductos =>
        groupedComprobantes.Values
            .SelectMany(c => c)
            .SelectMany(c => c.Detalles)
            .Sum(d => d.Cantidad);

    private double ProgressPercent => TotalProductos == 0 ? 0 : (double)TotalProductosIngresados / TotalProductos * 100d;

    // escaneo
    private System.Timers.Timer? escaneoTimer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!AuthService.IsAuthenticated)
            {
                loadError = "Sesión expirada.";
                return;
            }

            isLoading = true;
            loadError = null;

            var tipoEgreso = await SessionStorage.GetItemAsync<string>($"{guid}-TipoEgreso");
            var IdentificadorOrigen = await SessionStorage.GetItemAsync<string>($"{guid}-SelectedSecuencia");

            if (string.IsNullOrWhiteSpace(tipoEgreso) || string.IsNullOrWhiteSpace(IdentificadorOrigen))
            {
                loadError = "No se encontraron parámetros en la sesión.";
                return;
            }

            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            using var client = HttpClientFactory.CreateClient("Api");
            var urlrequest = $"store/OrigenMovimientoMercaderiaDetalle/{tipoEgreso}/{IdentificadorOrigen}/{guid}";
            var request = new HttpRequestMessage(HttpMethod.Get, urlrequest);
            var response = await client.SendAsync(request, ct);

            if (response.IsSuccessStatusCode)
            {
                var apiResult = await response.Content.ReadFromJsonAsync<Result<OrigenMovimiento>>(cancellationToken: ct);

                if (apiResult?.data == null)
                {
                    loadError = "No se encontraron datos para la secuencia indicada.";
                    return;
                }

                item = apiResult.data;

                if (item.Comprobantes != null)
                {
                    groupedComprobantes = item.Comprobantes
                        .GroupBy(c => c.SeqCompte ?? "Sin Compte")
                        .ToDictionary(g => g.Key, g => g.ToList());

                    groupKeys = groupedComprobantes.Keys.OrderBy(k => k).ToList();

                    if (groupKeys.Count > 0)
                    {
                        await SeleccionarCompte(groupKeys[0]);
                        _pendingInitialFocus = true;
                    }
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync(ct);
                var errorObj = System.Text.Json.JsonSerializer.Deserialize<Result<object>>(errorContent);

                loadError = $"Error cargando datos: {errorObj?.message ?? response.ReasonPhrase}";
            }

        }
        catch (Exception ex)
        {
            loadError = $"Error cargando datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("EgresoDetalleHeader.init", ".top-header", "#stickySentinel");
            }
            catch { /* no-op */ }
        }

        if (_pendingInitialFocus && !isLoading)
        {
            await FocusCodigoCapturaAsync();
            _pendingInitialFocus = false;
        }
    }

    string GetTipoName() => item?.TipoOrigen switch
    {
        "C" => "ID Cubicaje",
        "H" => "ID HojaRuta",
        "E" => "Compt. Egreso/Factur",
        _ => "Secuencia"
    };

    async Task SeleccionarCompte(string compte)
    {
        selectedCompte = compte;
        var primerComprobante = groupedComprobantes.TryGetValue(compte, out var lista)
            ? lista.FirstOrDefault()
            : null;

        if (primerComprobante != null)
        {
            selectedNumCompte = primerComprobante.NumCompte;
            selectedBodega = primerComprobante.Bodega;
        }
        else
        {
            selectedNumCompte = "";
            selectedBodega = "";
            selectedDetalle = null;
        }
        ResetCapturaActual();
        await InvokeAsync(StateHasChanged);
    }

    private (int captured, int expected) GetCompProgress(string key)
    {
        var comp = groupedComprobantes[key].First();
        var expected = comp.Detalles.Sum(d => d.Cantidad);
        var captured = comp.Detalles.Sum(d => d.CantidadIngresada);
        return (captured, expected);
    }

    private async Task HandleCodigoItemCaptura(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Code == "Enter" || e.Code == "NumpadEnter")
        {
            await Task.Delay(50);
            _codigoItemIngresado = codigoItemIngresado?.Trim() ?? string.Empty;
            await ValidarCodigoItem();
        }
    }

    private async Task HandleSerieCaptura(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Code == "Enter" || e.Code == "NumpadEnter")
        {
            await Task.Delay(50);
            serieIngresada = serieIngresada?.Trim() ?? string.Empty;
            await IngresarSerie();
        }
    }


    private async Task HandleCodigoItemInput(ChangeEventArgs e)
    {
        codigoItemIngresado = e.Value?.ToString() ?? string.Empty;

        // Reinicia el temporizador cada vez que se detecta una entrada
        escaneoTimer?.Stop();
        escaneoTimer?.Dispose();

        escaneoTimer = new System.Timers.Timer(200); // 200ms de espera sin teclear
        escaneoTimer.Elapsed += async (_, _) =>
        {
            escaneoTimer?.Stop();
            escaneoTimer?.Dispose();
            escaneoTimer = null;

            await InvokeAsync(async () =>
            {
                Console.WriteLine("Código leído: " + codigoItemIngresado);
                await ValidarCodigoItem();
            });
        };

        escaneoTimer.Start();
    }


    private async Task ValidarCodigoItem()
    {

        Console.WriteLine($"ValidarCodigoItem : {codigoItemIngresado}");

        productoNoEncontradoMessage = "";

        if (string.IsNullOrWhiteSpace(codigoItemIngresado) || string.IsNullOrWhiteSpace(selectedCompte))
            return;

        if (selectedDetalle?.CodigoItem == codigoItemIngresado)
            return;

        var primer = groupedComprobantes[selectedCompte].FirstOrDefault();
        var detalle = primer?.Detalles.FirstOrDefault(d =>
            string.Equals(d.CodigoItem, codigoItemIngresado, StringComparison.OrdinalIgnoreCase));

        if (detalle != null)
        {
            selectedDetalle = detalle;
            articuloDescripcion = detalle.Descripcion;
            codigoValido = true; // Marca código correcto (resalta en verde)
            serieIngresada = "";
            await FocusSerieCapturaAsync();
        }
        else
        {
            productoNoEncontradoMessage = "Producto no encontrado.";
            selectedDetalle = null;
            articuloDescripcion = string.Empty;
            codigoValido = false; // Quita estado de válido
            await FocusCodigoCapturaAsync();
        }

        await InvokeAsync(StateHasChanged);
    }


    private async Task<(bool, string)> controlSerie(SerieMovimiento serieMovimiento, string? accion)
    {
        try
        {
            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            using var client = HttpClientFactory.CreateClient("Api");

            var urlrequest = $"store/RegistrarSerieMovimiento/{guid}{(!string.IsNullOrEmpty(accion) ? $"?accion={accion}" : "")}";
            var request = new HttpRequestMessage(HttpMethod.Post, urlrequest)
            {
                Content = JsonContent.Create(serieMovimiento)
            };
            var response = await client.SendAsync(request, ct);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<Result<object>>(cancellationToken: ct);
                return (result?.succeeded ?? false, result?.message ?? "Error Serie: Error de conectividad");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync(ct);
                var errorObj = System.Text.Json.JsonSerializer.Deserialize<Result<object>>(errorContent);
                return (true, $"Error Serie: {errorObj?.message ?? response.ReasonPhrase}");
            }


        }
        catch (Exception ex)
        {
            return (false, ex.Message);
        }
    }

    private async Task IngresarSerie()
    {
        if (selectedDetalle == null)
        {
            productoNoEncontradoMessage = "Debe seleccionar un producto válido.";
            await FocusCodigoCapturaAsync();
            return;
        }



        if (string.IsNullOrWhiteSpace(serieIngresada))
        {
            await FocusSerieCapturaAsync();
            return;
        }


        if (selectedDetalle.CantidadIngresada >= selectedDetalle.Cantidad * (selectedDetalle.SeriesPorUnidad <= 0 ? 1 : selectedDetalle.SeriesPorUnidad))
        {
            await FocusSerieCapturaAsync();
            productoNoEncontradoMessage = "Cantidad de series ya completa para este artículo.";
            return;
        }

        selectedDetalle.SeriesCapturadas ??= new List<string>();

        if (selectedDetalle.SeriesCapturadas.Contains(serieIngresada, StringComparer.OrdinalIgnoreCase))
        {
            productoNoEncontradoMessage = "Serie ya ingresada.";
            return;
        }

        var (b, msg) = await controlSerie(new SerieMovimiento
        {
            SeqCompte = selectedCompte,
            CodigoItem = selectedDetalle.CodigoItem,
            Serie = serieIngresada.Trim()
        }, "INS");

        if (!b)
        {
            await FocusSerieCapturaAsync();
            productoNoEncontradoMessage = msg;
            return;
        }

        selectedDetalle.SeriesCapturadas.Add(serieIngresada.Trim());
        ResetCapturaActual();
        StateHasChanged();
    }

    private async Task<bool> RemoveSerie(string serie)
    {
        if (selectedDetalle?.SeriesCapturadas == null) return false;

        var (b, msg) = await controlSerie(new SerieMovimiento
        {
            SeqCompte = selectedCompte,
            CodigoItem = selectedDetalle.CodigoItem,
            Serie = serie
        }, "DEL");

        if (!b)
        {
            await FocusSerieCapturaAsync();
            productoNoEncontradoMessage = msg;
            return false;
        }
        selectedDetalle.SeriesCapturadas.Remove(serie);
        StateHasChanged();
        return true;
    }

    private void ResetCapturaActual()
    {
        serieIngresada = "";
        codigoItemIngresado = "";
        articuloDescripcion = "";
        selectedDetalle = null;
        productoNoEncontradoMessage = "";
        codigoValido = false; // Limpia el estado visual
        FocusCodigoCapturaAsync();
    }

    private int ExpectedSeriesFor(DetalleMovimiento? d)
    {
        if (d == null) return 0;
        var spUnit = d.SeriesPorUnidad <= 0 ? 1 : d.SeriesPorUnidad;
        return d.Cantidad * spUnit;
    }

    private bool CanFinalize()
        => item != null && TotalProductosIngresados > 0;

    private async Task FinalizarAsync()
    {
        if (item == null) return;
        postError = null;
        isPosting = true;

        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync("store/processOrigenMovimientoMercaderia", item);

            if (!response.IsSuccessStatusCode)
            {
                postError = $"Error HTTP {(int)response.StatusCode}: {response.ReasonPhrase}";
                return;
            }

            showFinalizeConfirm = false;
            showSuccess = true;
        }
        catch (Exception ex)
        {
            postError = $"Error enviando datos: {ex.Message}";
        }
        finally
        {
            isPosting = false;
        }
    }

    // Evento RowClick (cuando se requiera reactivar)
    private void OnDetalleRowClick(GridRowClickEventArgs args)
    {
        // if (args?.DataItem is DetalleMovimiento dm)
        // {
        //     selectedDetalle = dm;
        //     codigoItemIngresado = dm.CodigoItem;
        //     articuloDescripcion = dm.Descripcion;
        //     serieIngresada = "";
        //     productoNoEncontradoMessage = "";
        //     StateHasChanged();
        // }
    }


    private async Task FocusCodigoCapturaAsync()
    {
        try
        {
            if (txtCodigoCapturaRef is not null)
                await txtCodigoCapturaRef.FocusAsync();
            else
                await JS.InvokeVoidAsync("focusElementById", "txtCodigoCaptura");
        }
        catch { /* no-op */ }
    }

    private async Task FocusSerieCapturaAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("focusAndCenterById", "txtSerieCaptura");
        }
        catch
        {
            try
            {
                if (txtSerieCapturaRef is not null)
                    await txtSerieCapturaRef.FocusAsync();
                else
                    await JS.InvokeVoidAsync("focusElementById", "txtSerieCaptura");
            }
            catch { /* no-op */ }
        }
    }
}



<script>
    window.EgresoDetalleHeader = window.EgresoDetalleHeader || {
      init: function (headerSelector, sentinelSelector) {
        try {
          const header = document.querySelector(headerSelector);
          const sentinel = document.querySelector(sentinelSelector);
          if (!header || !sentinel) return;

          const setHeaderHeight = () => {
            const h = Math.round(header.getBoundingClientRect().height);
            document.documentElement.style.setProperty('--hdr-h', (h || 75) + 'px');
          };

          const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) header.classList.remove('compact');
              else header.classList.add('compact');
              setHeaderHeight();
            });
          }, { rootMargin: "0px 0px 0px 0px", threshold: [0, 1] });

          io.observe(sentinel);

          // Recalcular en resize/orientation change
          window.addEventListener('resize', setHeaderHeight, { passive: true });
          window.addEventListener('orientationchange', setHeaderHeight, { passive: true });

          // Observa cambios de clase (compact) para actualizar altura
          const mo = new MutationObserver(setHeaderHeight);
          mo.observe(header, { attributes: true, attributeFilter: ['class'] });

          // Inicial
          setHeaderHeight();
        } catch { /* noop */ }
      }
    };

    window.focusElementById = function (id) {
        var el = document.getElementById(id);
        if (el) {
            el.querySelector('input')?.focus();
        }
    };

        window.focusAndCenterById = function (id) {
        try {
            const host = document.getElementById(id);
            if (!host) return;

            const el = host.querySelector('input, textarea, select, [contenteditable="true"], button, a[href], [tabindex]:not([tabindex="-1"])') || host;

            // Si es la primera vez que se llama, esperar un poco antes de aplicar el scroll
            setTimeout(() => {
                // Desplazar el elemento al centro de la vista
                el.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'nearest' });

                // Enfocar el elemento, evitando el movimiento del scroll
                setTimeout(() => {
                    if (typeof el.focus === 'function') {
                        try {
                            el.focus({ preventScroll: true });
                        } catch {
                            el.focus();
                        }
                    }
                }, 50); // Le damos tiempo al scroll para que ocurra primero
            }, 100); // Este es el pequeño retraso para permitir que el navegador complete el layout
        } catch { /* no-op */ }
    };

</script>

