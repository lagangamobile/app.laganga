@page "/Bodega/EgresoComprobanteDetalle/{guid}"
@using System.Net.Http.Json
@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@inject NavigationManager Nav
@inject IAuthenticationService AuthService
@inject IApiGangaClient apiClient
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IJSRuntime JS


@if (isLoading)
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block info">Cargando información...</div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block error">
        @loadError

        <button type="button" class="btn retry-btn" @onclick="LoadDataAsync">Reintentar</button>
    </div>
}
else if (item == null)
{
    <h3 class="page-title">Egreso Comprobante - Detalle</h3>

    <div class="status-block warn">No se encontró información para la secuencia.</div>
}
else
{
    <div class="title-bar">
        <h3 class="page-title">@($"Despacho {GetTipoName()}: {item!.IdentificadorOrigenVisible}")</h3>

        <button type="button"
                class="@($"refresh-btn{(isLoading ? " spinning" : "")}")"
                @onclick="LoadDataAsync"
                disabled="@isLoading"
                aria-label="Actualizar"
                title="Actualizar">
            <svg class="refresh-icn" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                <polyline points="21 3 21 9 15 9" />
            </svg>
        </button>
    </div>

    <div class="detalle-root">

        <div id="stickySentinel" class="sticky-sentinel" aria-hidden="true"></div>

        <div class="top-header">
            <div class="progress-box">
                <div class="progress-info">
                    <span>Productos: <strong>@TotalProductosIngresados</strong>/<strong>@TotalProductos</strong></span>
                    <span class="small muted">(@ProgressPercent.ToString("0")%)</span>
                </div>
                <div class="progress-bar-outer">
                    <div class="progress-bar-inner" style="width:@($"{ProgressPercent}%")"></div>
                </div>
            </div>
            <div class="actions-inline">
                <button type="button" class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/Bodega/EgresoComprobante", true)'>Regresar</button>
                <button type="button" class="btn @(CanFinalize() ? "finalize" : "")" disabled="@(!CanFinalize())" @onclick="() => showFinalizeConfirm = true">Finalizar</button>
            </div>
        </div>

        <div class="comprobantes-wrapper">
            <div class="filters-row">
                <input type="text"
                       class="form-control form-control-sm manual-input"
                       placeholder="Buscar por #, bodega o destinatario"
                       aria-label="Buscar comprobante"
                       @bind="searchCompteText"
                       @bind:event="oninput" />
            </div>
            <div class="comprobantes-strip" role="tablist" aria-label="Comprobantes">
                @foreach (var key in FilteredGroupKeys)
                {
                    var comp = groupedComprobantes[key].First();
                    var (cap, exp) = GetCompProgress(key);
                    <button type="button"
                            data-comp-key="@key"
                            class="comp-card @(selectedCompte == key ? "selected" : "")"
                            role="tab"
                            aria-selected="@(selectedCompte == key ? "true" : "false")"
                            @onclick="() => SeleccionarCompte(key)">
                        <div class="comp-row">
                            <div class="comp-num">#@comp.NumCompte</div>
                            <div class="comp-bod">@($"Bod: {comp.Bodega}")</div>
                        </div>
                        <div class="comp-row">
                            <div class="comp-dest">@($"{comp.Destinatario}")</div>
                        </div>
                        <div class="comp-progress">
                            <div class="rail">
                                <div class="fill" style="width:@(exp == 0 ? "0%" : $"{Math.Min(100, (int)((double)cap / exp * 100))}%")"></div>
                            </div>
                            <div class="meta">@cap/@exp</div>
                        </div>
                        @if (selectedCompte == key)
                        {
                            <div class="chip-current">En captura</div>
                        }
                    </button>
                }
            </div>
        </div>

        @{
            var compSel = (!string.IsNullOrWhiteSpace(selectedCompte) && groupedComprobantes.TryGetValue(selectedCompte, out var listSel))
            ? listSel.FirstOrDefault()
            : null;
        }
        @if (compSel != null)
        {
            <details class="accordion-panel" id="detallesAccordion">
                <summary class="accordion-summary">
                    Detalles del comprobante (@(compSel.Detalles?.Sum(d => d.CantidadIngresada) ?? 0)/@(compSel.Detalles?.Sum(d => d.Cantidad) ?? 0))
                </summary>
                <div class="accordion-content">
                    <table class="table table-sm detalles-grid">
                        <thead>
                            <tr>
                                <th style="width:85px">Artículo</th>
                                <th>Descripción</th>
                                <th style="width:40px">Cant</th>
                                <th style="width:40px">Ing</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in compSel.Detalles ?? Enumerable.Empty<DetalleMovimiento>())
                            {
                                <tr class="@(d == selectedDetalle ? "table-active" : "")" @onclick="() => OnDetalleRowClick(d)" style="cursor:pointer">
                                    <td>@d.CodigoItem</td>
                                    <td>@d.Descripcion</td>
                                    <td>@d.Cantidad</td>
                                    <td>@d.CantidadIngresada</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        }

        <div class="capture-panel">
            <div class="section-title">Captura</div>
            <div class="responsive-grid">
                <div class="field-group">
                    <label for="txtCodigoCaptura" class="form-label form-label-sm">Código</label>
                    <input type="text"
                           id="txtCodigoCaptura"
                           class="form-control form-control-sm @(codigoValido ? "is-valid" : "")"
                           placeholder="Escanear / escribir código"
                           @ref="txtCodigoCapturaRef"
                           @bind="codigoItemIngresado"
                           @bind:event="oninput"
                           @onkeydown="HandleCodigoItemCaptura" />
                </div>

                <div class="field-compact" style='@(!codigoValido ? "display: none;" : "")'>
                    <div class="chip article-chip" title="@articuloDescripcion">
                        @(string.IsNullOrWhiteSpace(articuloDescripcion) ? "—" : articuloDescripcion)
                    </div>
                </div>

                <div class="field-group">
                    <label for="txtSerieCaptura" class="form-label form-label-sm">Serie</label>
                    <input type="text"
                           id="txtSerieCaptura"
                           class="form-control form-control-sm"
                           placeholder="Escanear serie"
                           @ref="txtSerieCapturaRef"
                           @bind="serieIngresada"
                           @bind:event="oninput"
                           @onkeydown="HandleSerieCaptura" />
                </div>
            </div>

            <div class="capture-actions">
                <button type="button" class="btn btn-primary btn-sm" disabled="@(selectedDetalle == null || string.IsNullOrWhiteSpace(serieIngresada))" @onclick="IngresarSerie">Ingresar Serie</button>
                <button type="button" class="btn btn-secondary btn-sm" @onclick="ResetCapturaActual">Limpiar</button>
            </div>

            @if (!string.IsNullOrEmpty(productoNoEncontradoMessage))
            {
                <div class="status-inline warn">@productoNoEncontradoMessage</div>
            }

            @if (selectedDetalle != null)
            {
                <div class="series-wrapper">
                    <div class="series-header">
                        Series capturadas (@selectedDetalle.SeriesCapturadas.Count):
                        <span class="small muted">
                            Esperadas: @ExpectedSeriesFor(selectedDetalle)
                        </span>
                    </div>
                    <div class="series-chips">
                        @foreach (var s in selectedDetalle.SeriesCapturadas)
                        {
                            <span class="chip">
                                @s
                                <button type="button" class="chip-remove" @onclick="() => RemoveSerie(s)">×</button>
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@if (showFinalizeConfirm)
{
    <div class="modal-backdrop" @onclick="() => showFinalizeConfirm = false">
        <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="finalizeTitle" @onclick:stopPropagation>
            <div class="modal-header">
                <h4 id="finalizeTitle" class="modal-title">Confirmar envío</h4>
                <button type="button"
                        class="modal-close"
                        title="Cerrar"
                        aria-label="Cerrar"
                        @onclick="() => showFinalizeConfirm = false">
                    ×
                </button>
            </div>
            <div class="modal-body">
                <p>Se enviará la información capturada. ¿Desea continuar?</p>
                <ul class="mini-list">
                    <li>Total productos ingresados: <strong>@TotalProductosIngresados</strong></li>
                    <li>Total productos: <strong>@TotalProductos</strong></li>
                    <li>Progreso: <strong>@ProgressPercent.ToString("0")%</strong></li>
                </ul>
                @if (!string.IsNullOrEmpty(postError))
                {
                    <div class="modal-error">@postError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" disabled="@isPosting" @onclick="CancelModalAsync">Cancelar</button>
                <button class="btn btn-primary" type="button" disabled="@( !CanFinalize() || isPosting )" @onclick="FinalizarAsync">Enviar</button>
            </div>
        </div>
    </div>
}


@code {
    [Parameter] public string guid { get; set; } = string.Empty;

    private string DataOrigen { get { return "tipo_origen"; }}

    private string tipoEgreso { get; set; } = string.Empty;
    private string IdentificadorOrigen { get; set; } = string.Empty;

    private ElementReference txtCodigoCapturaRef;
    private ElementReference txtSerieCapturaRef;

    private bool _pendingInitialFocus;
    private string? _pendingScrollCompteKey;

    private OrigenMovimiento? item;
    private Dictionary<string, List<ComprobanteMovimiento>> groupedComprobantes = new();
    private List<string> groupKeys = new();
    private string selectedCompte = "";
    private string selectedNumCompte = "";
    private string selectedBodega = "";
    private DetalleMovimiento? selectedDetalle;

    private bool isLoading = true;
    private string? loadError;
    private CancellationTokenSource? _cts;
    IDisposable? _navReg;
    bool datosCambiados = false;

    private string _codigoItemIngresado = "";
    private bool _inReset;

    private string codigoItemIngresado
    {
        get => _codigoItemIngresado;
        set
        {
            var newVal = value ?? string.Empty;
            var wasEmpty = string.IsNullOrEmpty(_codigoItemIngresado);
            _codigoItemIngresado = newVal;
            if (!_inReset && !wasEmpty && string.IsNullOrEmpty(newVal))
            {
                try
                {
                    _inReset = true;
                    ResetCapturaActual();
                }
                finally
                {
                    _inReset = false;
                }
            }
        }
    }

    private string articuloDescripcion = "";
    private string serieIngresada = "";
    private string productoNoEncontradoMessage = "";
    private bool codigoValido = false;

    private bool showFinalizeConfirm = false;
    private bool isPosting = false;
    private string? postError;

    // Filtro de comprobantes
    private string searchCompteText { get; set; } = string.Empty;

    private IReadOnlyList<string> FilteredGroupKeys =>
        string.IsNullOrWhiteSpace(searchCompteText)
            ? groupKeys
            : groupKeys.Where(k =>
            {
                var comp = groupedComprobantes.TryGetValue(k, out var list) ? list.FirstOrDefault() : null;
                if (comp == null) return false;
                var s = searchCompteText;
                return (!string.IsNullOrEmpty(comp.NumCompte) && comp.NumCompte.Contains(s, StringComparison.OrdinalIgnoreCase)) ||
                       (!string.IsNullOrEmpty(comp.Bodega) && comp.Bodega.Contains(s, StringComparison.OrdinalIgnoreCase)) ||
                       (!string.IsNullOrEmpty(comp.Destinatario) && comp.Destinatario.Contains(s, StringComparison.OrdinalIgnoreCase));
            }).ToList();
    private int TotalProductosIngresados =>
        groupedComprobantes.Values.SelectMany(c => c).SelectMany(c => c.Detalles).Sum(d => d.CantidadIngresada);

    private int TotalProductos =>
        groupedComprobantes.Values.SelectMany(c => c).SelectMany(c => c.Detalles).Sum(d => d.Cantidad);

    private double ProgressPercent => TotalProductos == 0 ? 0 : (double)TotalProductosIngresados / TotalProductos * 100d;


    protected override async Task OnInitializedAsync()
    {
        _navReg = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        AuthService.AuthenticationStateChanged += OnAuthChanged;

        if (!AuthService.IsAuthenticated)
            return;

        tipoEgreso = await SessionStorage.GetItemAsync<string>($"{guid}-TipoEgreso");
        IdentificadorOrigen = await SessionStorage.GetItemAsync<string>($"{guid}-SelectedSecuencia");

        if (string.IsNullOrWhiteSpace(tipoEgreso) || string.IsNullOrWhiteSpace(IdentificadorOrigen))
        {
            loadError = "No se encontraron parámetros en la sesión.";
            isLoading = false;
            return;
        }

        await LoadDataAsync();
    }

    private void OnAuthChanged()
    {
        if (!AuthService.IsAuthenticated)
        {
            try { _cts?.Cancel(); } catch (ObjectDisposedException) { }
            isLoading = false;
            loadError = "Sesión expirada.";
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            loadError = null;

            if (!AuthService.IsAuthenticated)
            {
                loadError = "Sesión no autenticada.";
                Nav.NavigateTo("/loginU", replace: true);
                return;
            }

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            var urlrequest = $"v1/bodega/OrigenMovimientoMercaderiaDetalle/{DataOrigen}/{tipoEgreso}/{IdentificadorOrigen}/{guid}";
            var response = await apiClient.GetAsync<OrigenMovimiento>(urlrequest, ct);

            if ((response?.succeeded ?? false) == false)
            {
                loadError = $"Error cargando datos: {response?.message ?? "Desconocido"}";
                return;
            }

            if (response?.data is null)
            {
                loadError = "No se encontraron datos para la secuencia indicada.";
                return;
            }

            item = response.data;

            if (item.Comprobantes != null)
            {
                groupedComprobantes = item.Comprobantes
                    .GroupBy(c => c.SeqCompte ?? "Sin Compte")
                    .ToDictionary(g => g.Key, g => g.ToList());

                groupKeys = groupedComprobantes.Keys.OrderBy(k => k).ToList();

                if (groupKeys.Count > 0)
                {
                    await SeleccionarCompte(groupKeys[0]);
                    _pendingInitialFocus = true;
                }
            }
        }
        catch (Exception ex)
        {
            loadError = $"Error cargando datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        //DESACTIVADO POR PRUEBAS -- REACTIVAR SI ES NECESAIRO

        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("EgresoDetalleHeader.init", ".top-header", "#stickySentinel");
            }
            catch { }
        }

        if (_pendingInitialFocus && !isLoading)
        {
            await FocusCodigoCapturaAsync();
            _pendingInitialFocus = false;
        }

        if (!string.IsNullOrEmpty(_pendingScrollCompteKey))
        {
            try
            {
                await JS.InvokeVoidAsync("scrollCompteIntoView", _pendingScrollCompteKey);
            }
            catch { }
            _pendingScrollCompteKey = null;
        }
    }

    private async Task<bool> AskBeforeLeavingAsync()
    {
        //desactivado temporalmente
        datosCambiados = false;
        if (!datosCambiados) return false;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de que desea abandonar los cambios?");
        return !confirmed;
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!await AskBeforeLeavingAsync()) return;
        context.PreventNavigation();
    }

    string GetTipoName() => item?.TipoOrigen switch
    {
        "C" => "ID Cubicaje",
        "H" => "ID HojaRuta",
        "E" => "Compt. Egreso/Factur",
        _ => "Secuencia"
    };

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthChanged;

        try { _cts?.Cancel(); } catch (ObjectDisposedException) { }
        _cts?.Dispose();
        _cts = null;

        _navReg?.Dispose();
    }


    private void OnDetalleRowClick(DetalleMovimiento detalle)
    {
    }

    async Task SeleccionarCompte(string compte)
    {
        selectedCompte = compte;
        var primerComprobante = groupedComprobantes.TryGetValue(compte, out var lista)
            ? lista.FirstOrDefault()
            : null;

        if (primerComprobante != null)
        {
            selectedNumCompte = primerComprobante.NumCompte;
            selectedBodega = primerComprobante.Bodega;
        }
        else
        {
            selectedNumCompte = "";
            selectedBodega = "";
            selectedDetalle = null;
        }
        await ResetCapturaActual();
        _pendingScrollCompteKey = selectedCompte;
        await InvokeAsync(StateHasChanged);
    }

    private (int captured, int expected) GetCompProgress(string key)
    {
        var comp = groupedComprobantes[key].First();
        var expected = comp.Detalles.Sum(d => d.Cantidad);
        var captured = comp.Detalles.Sum(d => d.CantidadIngresada);
        return (captured, expected);
    }

    private async Task HandleCodigoItemCaptura(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter")
        {
            await Task.Delay(50);
            _codigoItemIngresado = codigoItemIngresado?.Trim() ?? string.Empty;
            await ValidarCodigoItem();
        }
    }

    private async Task HandleSerieCaptura(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter")
        {
            await Task.Delay(50);
            serieIngresada = serieIngresada?.Trim() ?? string.Empty;
            await IngresarSerie();
        }
    }

    private async Task ValidarCodigoItem()
    {
        productoNoEncontradoMessage = "";

        if (string.IsNullOrWhiteSpace(codigoItemIngresado) || string.IsNullOrWhiteSpace(selectedCompte))
            return;

        if (selectedDetalle?.CodigoItem == codigoItemIngresado || selectedDetalle?.CodigoFabrica == codigoItemIngresado)
            return;

        var primer = groupedComprobantes[selectedCompte].FirstOrDefault();
        var detalle = primer?.Detalles.FirstOrDefault(d =>
            string.Equals(d.CodigoItem, codigoItemIngresado, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(d.CodigoFabrica, codigoItemIngresado, StringComparison.OrdinalIgnoreCase));

        if (detalle != null)
        {
            selectedDetalle = detalle;
            articuloDescripcion = detalle.Descripcion;
            codigoValido = true;
            serieIngresada = "";
            await FocusSerieCapturaAsync();
        }
        else
        {
            productoNoEncontradoMessage = "Producto no encontrado.";
            selectedDetalle = null;
            articuloDescripcion = string.Empty;
            codigoValido = false;
            await FocusCodigoCapturaAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<(bool ok, string msg)> controlSerie(SerieMovimiento serieMovimiento, string? accion)
    {
        try
        {
            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            var urlrequest = $"v1/bodega/RegistrarSerieMovimiento{(!string.IsNullOrEmpty(accion) ? $"?accion={accion}" : "")}";
            var response = await apiClient.PostAsync<object>(urlrequest, serieMovimiento, ct);
            return (response?.succeeded ?? false, response?.message ?? "Error inesperado al registrar serie.");
        }
        catch (Exception ex)
        {
            return (false, ex.Message);
        }
    }

    private async Task IngresarSerie()
    {
        productoNoEncontradoMessage = "";
        if (selectedDetalle == null)
        {
            productoNoEncontradoMessage = "Debe seleccionar un producto válido.";
            await FocusCodigoCapturaAsync();
            return;
        }

        if (string.IsNullOrWhiteSpace(serieIngresada))
        {
            await FocusSerieCapturaAsync();
            return;
        }

        if (IsDetalleComplete(selectedDetalle))
        {
            productoNoEncontradoMessage = "Cantidad de series ya completa para este artículo.";
            await FocusSerieCapturaAsync();
            return;
        }

        selectedDetalle.SeriesCapturadas ??= new List<string>();

        if (selectedDetalle.SeriesCapturadas.Contains(serieIngresada, StringComparer.OrdinalIgnoreCase))
        {
            productoNoEncontradoMessage = "Serie ya ingresada.";
            return;
        }

        var (ok, msg) = await controlSerie(new SerieMovimiento
        {
            Guid = Guid.Parse(guid),
            SeqCompte = selectedCompte,
            CodigoItem = selectedDetalle.CodigoItem,
            Serie = serieIngresada.Trim()
        }, "INS");

        if (!ok)
        {
            productoNoEncontradoMessage = msg;
            await FocusSerieCapturaAsync();
            return;
        }

        selectedDetalle.SeriesCapturadas.Add(serieIngresada.Trim());
        datosCambiados = true;

        // if (IsComprobanteComplete(selectedCompte))
        // {
        //     await CheckAndAdvanceComprobanteIfCompleteAsync();
        //     return;
        // }

        if (IsDetalleComplete(selectedDetalle))
        {
            await ResetCapturaActual();
            return;
        }

        serieIngresada = "";
        productoNoEncontradoMessage = "";
        await FocusSerieCapturaAsync();
        StateHasChanged();
    }

    private async Task<bool> RemoveSerie(string serie)
    {
        if (selectedDetalle?.SeriesCapturadas == null) return false;

        var (ok, msg) = await controlSerie(new SerieMovimiento
        {
            Guid = Guid.Parse(guid),
            SeqCompte = selectedCompte,
            CodigoItem = selectedDetalle.CodigoItem,
            Serie = serie
        }, "DEL");

        if (!ok)
        {
            productoNoEncontradoMessage = msg;
            await FocusSerieCapturaAsync();
            return false;
        }

        selectedDetalle.SeriesCapturadas.Remove(serie);
        StateHasChanged();
        return true;
    }

    private async Task ResetCapturaActual()
    {
        serieIngresada = "";
        codigoItemIngresado = "";
        articuloDescripcion = "";
        selectedDetalle = null;
        productoNoEncontradoMessage = "";
        codigoValido = false;
        await FocusCodigoCapturaAsync();
        StateHasChanged();
    }

    private int ExpectedSeriesFor(DetalleMovimiento? d)
    {
        if (d == null) return 0;
        var spUnit = d.SeriesPorUnidad <= 0 ? 1 : d.SeriesPorUnidad;
        return d.Cantidad * spUnit;
    }

    private bool CanFinalize() => item != null && TotalProductosIngresados > 0;

    private async Task CancelModalAsync()
    {
        datosCambiados = true;
        showFinalizeConfirm = false;
        await Task.CompletedTask;
    }

    private async Task FinalizarAsync()
    {
        datosCambiados = false;
        await SessionStorage.SetItemAsync($"{guid}-OrigenMovimientoDespacho", item);
        Nav.NavigateTo($"/Bodega/EgresoComprobanteResumen/{guid}");
    }

    private async Task FocusCodigoCapturaAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("focusElementById", "txtCodigoCaptura");
        }
        catch { }
    }

    private async Task FocusSerieCapturaAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("focusAndCenterById", "txtSerieCaptura");
        }
        catch
        {
            try
            {
                await JS.InvokeVoidAsync("focusElementById", "txtSerieCaptura");
            }
            catch { }
        }
    }

    private int SeriesIngresadasFor(DetalleMovimiento d)
    {
        if (d == null) return 0;
        if (d.TotalSeriesIngresadas > 0) return d.TotalSeriesIngresadas;
        return d.SeriesCapturadas?.Count ?? 0;
    }

    private bool IsDetalleComplete(DetalleMovimiento d)
    {
        var expected = ExpectedSeriesFor(d);
        if (expected > 0)
        {
            var ingresadas = SeriesIngresadasFor(d);
            return ingresadas >= expected;
        }
        return d.CantidadIngresada >= d.Cantidad;
    }

    private bool IsComprobanteComplete(string key)
    {
        if (string.IsNullOrWhiteSpace(key)) return false;
        if (!groupedComprobantes.TryGetValue(key, out var lista) || lista.Count == 0) return false;
        var comp = lista.First();
        if (comp.Detalles == null || comp.Detalles.Count == 0) return true;
        return comp.Detalles.All(IsDetalleComplete);
    }

    private string? FindNextIncompleteKey(string fromKey)
    {
        if (groupKeys == null || groupKeys.Count == 0) return null;
        var start = Math.Max(0, groupKeys.IndexOf(fromKey));
        for (int i = 1; i <= groupKeys.Count; i++)
        {
            var idx = (start + i) % groupKeys.Count;
            var key = groupKeys[idx];
            if (!IsComprobanteComplete(key))
                return key;
        }
        return null;
    }

    private async Task CheckAndAdvanceComprobanteIfCompleteAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedCompte)) return;
        if (IsComprobanteComplete(selectedCompte))
        {
            var next = FindNextIncompleteKey(selectedCompte);
            if (!string.IsNullOrWhiteSpace(next))
                await SeleccionarCompte(next);
        }
    }
}



<script>
    window.EgresoDetalleHeader = window.EgresoDetalleHeader || {
      init: function (headerSelector, sentinelSelector) {
        try {
          const header = document.querySelector(headerSelector);
          const sentinel = document.querySelector(sentinelSelector);
          if (!header || !sentinel) return;

          const setHeaderHeight = () => {
            const h = Math.round(header.getBoundingClientRect().height);
            document.documentElement.style.setProperty('--hdr-h', (h || 75) + 'px');
          };

          const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) header.classList.remove('compact');
              else header.classList.add('compact');
              setHeaderHeight();
            });
          }, { rootMargin: "0px 0px 0px 0px", threshold: [0, 1] });

          io.observe(sentinel);

          window.addEventListener('resize', setHeaderHeight, { passive: true });
          window.addEventListener('orientationchange', setHeaderHeight, { passive: true });

          const mo = new MutationObserver(setHeaderHeight);
          mo.observe(header, { attributes: true, attributeFilter: ['class'] });

          setHeaderHeight();
        } catch { }
      }
    };

    window.focusElementById = function (id) {
        var el = document.getElementById(id);
        if (el) {
            el.querySelector('input')?.focus();
        }
    };

    window.focusAndCenterById = function (id) {
        try {
            const host = document.getElementById(id);
            if (!host) return;
            const el = host.querySelector('input, textarea, select, [contenteditable="true"], button, a[href], [tabindex]:not([tabindex="-1"])') || host;
            setTimeout(() => {
                el.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'nearest' });
                setTimeout(() => {
                    if (typeof el.focus === 'function') {
                        try {
                            el.focus({ preventScroll: true });
                        } catch {
                            el.focus();
                        }
                    }
                }, 50);
            }, 100);
        } catch { }
    };

    window.scrollCompteIntoView = function (key) {
        try {
            const strip = document.querySelector('.comprobantes-strip');
            if (!strip) return;
            const btn = strip.querySelector('[data-comp-key="' + key + '"]');
            if (!btn) return;

            const stripRect = strip.getBoundingClientRect();
            const btnRect = btn.getBoundingClientRect();

            const fullyVisible = btnRect.left >= stripRect.left && btnRect.right <= stripRect.right;
            if (fullyVisible) return;

            const targetLeft = btn.offsetLeft - (strip.clientWidth - btn.offsetWidth) / 2;
            strip.scrollTo({ left: Math.max(0, targetLeft), behavior: 'smooth' });
        } catch { }
    };


    document.addEventListener("DOMContentLoaded", function() {
        const scrollContainer = document.querySelector('.detalle-scroll');
        const codigoHost = document.getElementById('txtCodigoCaptura');
        const serieHost = document.getElementById('txtSerieCaptura');

        const ensureVisible = (host) => {
          if (!host || !scrollContainer) return;
          const rect = host.getBoundingClientRect();
          const parentRect = scrollContainer.getBoundingClientRect();
          if (rect.bottom > parentRect.bottom || rect.top < parentRect.top) {
            scrollContainer.scrollTo({
              top: scrollContainer.scrollTop + (rect.top - parentRect.top) - 40,
              behavior: 'smooth'
            });
          }
        };

        codigoHost?.addEventListener('focusin', () => ensureVisible(codigoHost));
        serieHost?.addEventListener('focusin', () => ensureVisible(serieHost));
    });


</script>


