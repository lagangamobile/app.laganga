@page "/Bodega/EgresoComprobanteResumen/{guid}"
@using System.Net.Http.Json
@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@inject NavigationManager Nav
@inject IAuthenticationService AuthService
@inject IApiGangaClient apiClient
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

@inject IJSRuntime JS

@if (isLoading)
{
    <h3 class="page-title">Egreso Comprobante - Resumen</h3>
    <div class="status-block info">Cargando información...</div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <h3 class="page-title">Egreso Comprobante - Resumen</h3>
    <div class="status-block error">@loadError</div>
}
else if (item == null)
{
    <h3 class="page-title">Egreso Comprobante - Resumen</h3>
    <div class="status-block warn">No se encontró información para la secuencia.</div>
}
else
{
    <h3 class="page-title">@($"Resumen {GetTipoName()}: {item!.IdentificadorOrigenVisible}")</h3>

    <div class="resumen-root">

        <div id="stickySentinel" class="sticky-sentinel" aria-hidden="true"></div>

        <div class="top-header">
            <div class="header-line">


                <div class="progress-box">
                    <div class="progress-info">
                        <span>Comprobantes: <strong>@TotalComprobantes</strong></span>
                        <span>Productos: <strong>@TotalProductosIngresados</strong>/<strong>@TotalProductos</strong></span>
                        <span class="small muted">(@ProgressPercent.ToString("0")%)</span>
                    </div>
                    <div class="progress-bar-outer">
                        <div class="progress-bar-inner" style="width:@($"{ProgressPercent}%")"></div>
                    </div>
                </div>


                <div class="actions-inline">
                    <button type="button" class="btn btn-secondary" @onclick='() => Nav.NavigateTo($"/Bodega/EgresoComprobanteDetalle/{guid}", true)'>Regresar</button>

                    <button type="button" class="btn btn-success" disabled="@isProcessing" @onclick="OpenFinalizeModal">Finalizar</button>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(plateError))
            {
                <small class="chip-error" role="alert">@plateError</small>
            }

            <div class="manual-grid">
                <span class="chip plate-chip accent">
                    <span class="chip-label">Placa</span>

                    @if (!editingPlate)
                    {
                        <span class="chip-value">@item.ReferenciaOrigen</span>
                        <button type="button"
                                class="chip-icon-btn"
                                title="Editar placa"
                                aria-label="Editar placa"
                                @onclick="BeginEditPlate">
                            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                <path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.33H5v-.92l8.06-8.06.92.92L5.92 19.58zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"></path>
                            </svg>
                        </button>
                    }
                    else
                    {
                        <input class="chip-input upper-input"
                               placeholder="ABC123"
                               @bind="plateEditValue"
                               @bind:event="oninput"
                               maxlength="12"
                               aria-label="Placa" />

                        <button type="button"
                                class="chip-icon-btn success"
                                title="Guardar"
                                aria-label="Guardar placa"
                                disabled="@savingPlate"
                                @onclick="SavePlateAsync">
                            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                <path fill="currentColor" d="M9 16.2l-3.5-3.5L4 14.2l5 5 12-12-1.5-1.5z"></path>
                            </svg>
                        </button>

                        <button type="button"
                                class="chip-icon-btn danger"
                                title="Cancelar"
                                aria-label="Cancelar edición"
                                disabled="@savingPlate"
                                @onclick="CancelEditPlate">
                            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                <path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path>
                            </svg>
                        </button>
                    }
                </span>
            </div>

            <div class="summary-chips" role="group" aria-label="Detalle de totales">
                <span class="chip">
                    <span class="chip-label">Tipo</span>
                    <span class="chip-value">@GetTipoName()</span>
                </span>
                <span class="chip">
                    <span class="chip-label">Número</span>
                    <span class="chip-value">@item.IdentificadorOrigen</span>
                </span>
                <span class="chip">
                    <span class="chip-label">Visible</span>
                    <span class="chip-value">@item.IdentificadorOrigenVisible</span>
                </span>
                <span class="chip">
                    <span class="chip-label">Comprobantes</span>
                    <span class="chip-value">@TotalComprobantes</span>
                </span>
                <span class="chip success" title="Progreso de productos">
                    <span class="chip-label">Productos</span>
                    <span class="chip-value">@TotalProductosIngresados/@TotalProductos</span>
                    <small class="chip-note">@ProgressPercent.ToString("0")%</small>
                </span>

            </div>
        </div>

        <section class="items-section">
            <div class="items-grid" role="list" aria-label="Listado de comprobantes">
                @foreach (var comp in item.Comprobantes ?? Enumerable.Empty<ComprobanteMovimiento>())
                {
                    var expected = comp.Detalles?.Sum(d => d.Cantidad) ?? 0;
                    var captured = comp.Detalles?.Sum(d => d.CantidadIngresada) ?? 0;
                    var percent = expected == 0 ? 0 : Math.Min(100, (int)((double)captured / expected * 100));

                    <div class="comp-card"
                         role="listitem"
                         tabindex="0"
                         title="@($"Compte #{comp.NumCompte} - Bodega {comp.Bodega}")"
                         @onclick="() => OpenCompModal(comp)">
                        <div class="comp-row">
                            <div class="comp-num">#@comp.NumCompte</div>
                            <div class="comp-bod">@($"Bod: {comp.Bodega}")</div>
                        </div>
                        <div class="comp-row">
                            @* <div class="comp-date">@comp.Fecha:dd/MM/yyyy</div> *@
                            <div class="comp-dest">@($"{comp.Destinatario}")</div>
                            <div class="comp-meta">@($"{captured}/{expected}")</div>
                        </div>
                        <div class="comp-progress">
                            <div class="rail">
                                <div class="fill" style="width:@($"{percent}%")"></div>
                            </div>
                            <div class="meta">@percent%</div>
                        </div>

                        @if (captured >= expected && expected > 0)
                        {
                            <div class="chip-current" title="Completo">OK</div>
                        }
                    </div>
                }
            </div>
        </section>

        @* Modal de edición de comprobante *@
        @if (showCompModal && selectedComp is not null)
        {
            <div class="modal-backdrop" @onclick="OnBackdropClick">
                <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="compModalTitle" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h4 id="compModalTitle" class="modal-title">Comprobante #@selectedComp.NumCompte</h4>
                        <button type="button" class="modal-close" title="Cerrar" aria-label="Cerrar" @onclick="CloseCompModal">×</button>
                    </div>

                    <div class="modal-body">
                        <div class="modal-row">
                            <label class="modal-label">Cuidad Destino</label>
                            <div class="modal-text">@selectedComp.DestinoCiudad</div>
                        </div>
                        <div class="modal-row">
                            <label class="modal-label" for="destInput">Destinatario</label>
                            <input id="destInput"
                                   class="modal-input"
                                   @bind="destinatarioEdit"
                                   @bind:event="oninput"
                                   placeholder="Destinatario" />
                        </div>
                        <div class="modal-row">
                            <label class="modal-label" for="puntoInput">Punto de llegada</label>
                            <input id="puntoInput"
                                   class="modal-input"
                                   @bind="puntoLlegadaEdit"
                                   @bind:event="oninput"
                                   placeholder="Punto de llegada" />
                        </div>
                        <div class="modal-row">
                            <label class="modal-label" for="comentarioInput">Comentario</label>
                            <input id="comentarioInput"
                                   class="modal-input"
                                   @bind="ComentarioEdit"
                                   @bind:event="oninput"
                                   placeholder="Comentario" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(compModalError))
                        {
                            <div class="modal-error">@compModalError</div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseCompModal" disabled="@savingComp">Cerrar</button>
                        <button class="btn btn-primary" type="button" @onclick="SaveCompAsync" disabled="@savingComp">
                            @(savingComp ? "Grabando..." : "Grabar")
                        </button>
                    </div>
                </div>
            </div>
        }

        @* Modal de confirmación Finalizar *@
        @if (showFinalizeModal)
        {
            <div class="modal-backdrop">
                <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="finalizeTitle" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h4 id="finalizeTitle" class="modal-title">Confirmar</h4>
                        <button type="button" class="modal-close" title="Cerrar" aria-label="Cerrar" @onclick="CloseFinalizeModal" disabled="@isProcessing">×</button>
                    </div>
                    <div class="modal-body">
                        <p>¿Está seguro de finalizar la acción?</p>

                        <!-- Progreso radial centrado usando @ProgressPercent -->
                        <div class="finalize-center"
                             role="img"
                             aria-label="@($"{ProgressPercent:0}% completado. {TotalProductosIngresados} de {TotalProductos} productos.")">
                            <div class="radial" style="--p:@ProgressPercent">
                                <div class="radial-inner">
                                    <div class="radial-text">@TotalProductosIngresados/@TotalProductos</div>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(finalizeError))
                        {
                            <div class="modal-error">@finalizeError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseFinalizeModal" disabled="@isProcessing">Cancelar</button>
                        <button class="btn btn-primary" type="button" @onclick="ConfirmFinalizeAsync" disabled="@isProcessing">Aceptar</button>
                    </div>
                </div>
            </div>
        }

        @* Overlay de bloqueo durante el procesamiento *@
        @if (isProcessing)
        {
            <div class="blocker-backdrop" role="alert" aria-busy="true" aria-live="polite">
                <div class="blocker-card">
                    <div class="progress-circle lg" aria-hidden="true"></div>
                    <div class="blocker-text">Procesando, por favor espere...</div>
                </div>
            </div>
        }

        @if (showSuccess)
        {
            <div class="modal-backdrop">
                <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="successTitle" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h4 id="successTitle" class="modal-title">Procesado</h4>
                    </div>
                    <div class="modal-body">
                        <p>Datos enviados correctamente.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-primary" type="button" @onclick='() => Nav.NavigateTo("/Bodega/EgresoComprobante", true)'>Aceptar</button>
                    </div>
                </div>
            </div>
        }

    </div>
}

@code
{
    [Parameter] public string guid { get; set; } = string.Empty;

    private OrigenMovimiento? item;
    private bool isLoading = true;
    private string? loadError;

    // Estado de edición de placa
    private bool editingPlate = false;
    private string plateEditValue = string.Empty;
    private bool savingPlate = false;
    private string? plateError;

    // Estado modal de comprobante
    private bool showCompModal = false;
    private ComprobanteMovimiento? selectedComp;
    private string? destinatarioEdit;
    private string? puntoLlegadaEdit;
    private string? ComentarioEdit;
    private bool savingComp = false;
    private string? compModalError;

    // Finalización
    private bool showSuccess = false;
    private bool showFinalizeModal = false;
    private bool isProcessing = false;
    private string? finalizeError;

    private int TotalComprobantes => item?.Comprobantes?.Count ?? 0;

    private int TotalProductosIngresados =>
        item?.Comprobantes?
            .SelectMany(c => c.Detalles ?? new List<DetalleMovimiento>())
            .Sum(d => d.CantidadIngresada) ?? 0;

    private int TotalProductos =>
        item?.Comprobantes?
            .SelectMany(c => c.Detalles ?? new List<DetalleMovimiento>())
            .Sum(d => d.Cantidad) ?? 0;

    private double ProgressPercent => TotalProductos == 0 ? 0 : (double)TotalProductosIngresados / TotalProductos * 100d;

    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!AuthService.IsAuthenticated)
            {
                loadError = "Sesión expirada.";
                return;
            }

            isLoading = true;
            loadError = null;

            var tipoEgreso = await SessionStorage.GetItemAsync<string>($"{guid}-TipoEgreso");
            var IdentificadorOrigen = await SessionStorage.GetItemAsync<string>($"{guid}-SelectedSecuencia");

            item = await SessionStorage.GetItemAsync<OrigenMovimiento>($"{guid}-OrigenMovimientoDespacho");

        }
        catch (Exception ex)
        {
            loadError = $"Error cargando datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnAuthChanged()
    {
        // Si expira el token estando en la pantalla, detiene cargas y deja que Routes.razor redirija.
        if (!AuthService.IsAuthenticated)
        {
            _cts?.Cancel();
            isLoading = false;
            loadError = "Sesión expirada.";
            InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("EgresoDetalleHeader.init", ".top-header", "#stickySentinel");
            }
            catch { /* no-op */ }
        }
    }

    private string GetTipoName() => item?.TipoOrigen switch
    {
        "C" => "Cubicaje",
        "H" => "Hoja de Ruta",
        "E" => "Compt. Egreso/Factura",
        _ => "Secuencia"
    };

    // --- Modal comprobante ---
    private void OpenCompModal(ComprobanteMovimiento comp)
    {
        selectedComp = comp;
        destinatarioEdit = comp.Destinatario;
        puntoLlegadaEdit = comp.PuntoLlegada;
        ComentarioEdit = comp.Comentario;
        compModalError = null;
        showCompModal = true;
        StateHasChanged();
    }

    private void CloseCompModal()
    {
        showCompModal = false;
        compModalError = null;
        savingComp = false;
        selectedComp = null;
        destinatarioEdit = null;
        puntoLlegadaEdit = null;
        ComentarioEdit = null;
    }

    private void OnBackdropClick(MouseEventArgs _)
    {
        CloseCompModal();
    }

    private async Task SaveCompAsync()
    {
        if (selectedComp is null || string.IsNullOrWhiteSpace(guid)) return;

        compModalError = null;
        savingComp = true;

        // Construye DTO sin detalles y con campos modificados
        var dto = new ComprobanteMovimiento
        {
            SeqCompte = selectedComp.SeqCompte,
            NumCompte = selectedComp.NumCompte,
            Destinatario = (destinatarioEdit ?? string.Empty).Trim(),
            PuntoLlegada = (puntoLlegadaEdit ?? string.Empty).Trim(),
            Comentario = (ComentarioEdit ?? string.Empty).Trim(),
            Detalles = null
        };

        try
        {

            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            var url = $"v1/bodega/EditarComprobanteMovimiento/des/{guid}";
            var resp = await apiClient.PostAsync<ComprobanteMovimiento>(url, dto,ct);

            if (resp?.succeeded == true)
            {
                // Actualiza el modelo en memoria
                selectedComp.Destinatario = dto.Destinatario;
                selectedComp.PuntoLlegada = dto.PuntoLlegada;

                CloseCompModal();
            }
            else
            {
                compModalError = resp?.message ?? "No se pudo grabar el comprobante.";
            }
        }
        catch (Exception ex)
        {
            compModalError = $"Error grabando: {ex.Message}";
        }
        finally
        {
            savingComp = false;
            StateHasChanged();
        }
    }

    // --- Finalización (confirmación y procesamiento) ---
    private void OpenFinalizeModal()
    {
        finalizeError = null;
        showFinalizeModal = true;
    }

    private void CloseFinalizeModal()
    {
        if (isProcessing) return;
        showFinalizeModal = false;
        finalizeError = null;
    }

    private async Task ConfirmFinalizeAsync()
    {
        if (item is null)
        {
            finalizeError = "No hay datos para procesar.";
            return;
        }

        try
        {
            isProcessing = true;
            showFinalizeModal = false;
            finalizeError = null;

            // Enviar OrigenMovimiento (DTO reducido)
            var dto = new OrigenMovimiento
            {
                Guid = item.Guid,
                TipoOrigen = item.TipoOrigen,
                IdentificadorOrigen = item.IdentificadorOrigen,
                IdentificadorOrigenVisible = item.IdentificadorOrigenVisible,
                Estado = item.Estado,
                ReferenciaOrigen = item.ReferenciaOrigen,
                TipoLogistica = item.TipoLogistica,
                ReferenciaLogistica = item.ReferenciaLogistica,
                Comprobantes = null
            };


            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;
            
            var resp = await apiClient.PostAsync<OrigenMovimiento>("v1/bodega/ProcesarOrigenMovimiento/pro", dto, ct);

            if (resp?.succeeded == true)
            {
                showSuccess = true;
            }
            else
            {
                finalizeError = resp?.message ?? "No se pudo procesar la información.";
                showFinalizeModal = true; // reabrir para permitir reintento
            }
        }
        catch (Exception ex)
        {
            finalizeError = $"Error procesando: {ex.Message}";
            showFinalizeModal = true;
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    // --- Edición de placa (chip manual-grid) ---
    private void BeginEditPlate()
    {
        plateError = null;
        plateEditValue = item?.ReferenciaOrigen ?? string.Empty;
        editingPlate = true;
    }

    private void CancelEditPlate()
    {
        plateError = null;
        plateEditValue = string.Empty;
        editingPlate = false;
    }

    private async Task SavePlateAsync()
    {
        if (item is null) return;

        plateError = null;
        var newValue = (plateEditValue ?? string.Empty).Trim().ToUpperInvariant();

        if (string.IsNullOrWhiteSpace(newValue))
        {
            plateError = "La placa no puede estar vacía.";
            return;
        }

        savingPlate = true;
        var previous = item.ReferenciaOrigen;

        try
        {
            item.ReferenciaOrigen = newValue;

            var dto = new OrigenMovimiento()
            {
                Guid = item.Guid,
                TipoOrigen = item.TipoOrigen,
                IdentificadorOrigen = item.IdentificadorOrigen,
                ReferenciaOrigen = item.ReferenciaOrigen
            };

            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            // POST al endpoint con el objeto completo
            var resp = await apiClient.PostAsync<OrigenMovimiento>("v1/bodega/EditarOrigenMovimiento/ref", dto, ct);

            if (resp?.succeeded == true)
            {
                editingPlate = false;
            }
            else
            {
                // Revertimos el valor si falló
                item.ReferenciaOrigen = previous;
                plateError = resp?.message ?? "No se pudo guardar la placa.";
            }
        }
        catch (Exception ex)
        {
            item.ReferenciaOrigen = previous;
            plateError = $"Error guardando: {ex.Message}";
        }
        finally
        {
            savingPlate = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}

<script>
    window.EgresoDetalleHeader = window.EgresoDetalleHeader || {
        init: function (headerSelector, sentinelSelector) {
            try {
                const header = document.querySelector(headerSelector);
                const sentinel = document.querySelector(sentinelSelector);
                if (!header || !sentinel) return;

                const setHeaderHeight = () => {
                    const h = Math.round(header.getBoundingClientRect().height);
                    document.documentElement.style.setProperty('--hdr-h', (h || 75) + 'px');
                };

                const io = new IntersectionObserver((entries) => {
                    entries.forEach(e => {
                        if (e.isIntersecting) header.classList.remove('compact');
                        else header.classList.add('compact');
                        setHeaderHeight();
                    });
                }, { rootMargin: "0px 0px 0px 0px", threshold: [0, 1] });

                io.observe(sentinel);
                window.addEventListener('resize', setHeaderHeight, { passive: true });
                window.addEventListener('orientationchange', setHeaderHeight, { passive: true });

                const mo = new MutationObserver(setHeaderHeight);
                mo.observe(header, { attributes: true, attributeFilter: ['class'] });

                setHeaderHeight();
            } catch { /* noop */ }
        }
    };
</script>

<style>
    .page-title {
        margin-bottom: .5rem;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .resumen-root {
        display: flex;
        flex-direction: column;
        gap: .75rem;
        padding-bottom: 1rem;
    }

    .sticky-sentinel {
        position: relative;
        width: 100%;
        height: 1px;
    }

    .status-block {
        padding: .75rem 1rem;
        border-radius: 6px;
        font-size: .9rem;
    }

        .status-block.info {
            background: #e8f4ff;
            color: #024c7b;
        }

        .status-block.error {
            background: #ffe8e8;
            color: #7b0202;
        }

        .status-block.warn {
            background: #fff7e0;
            color: #6b4d00;
        }

    .top-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--dxbl-background, #fff);
        display: flex;
        flex-direction: column;
        gap: .75rem;
        padding: .6rem .75rem .9rem;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        border-radius: 8px;
    }

        .top-header.compact {
            padding: .35rem .5rem .5rem;
            gap: .45rem;
        }

    .header-line {
        display: flex;
        gap: .75rem;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .progress-box {
        display: flex;
        flex-direction: column;
        gap: .35rem;
        min-width: 220px;
        width: 100%;
    }

    .progress-info {
        display: flex;
        align-items: baseline;
        gap: .6rem;
        font-size: .85rem;
        flex-wrap: wrap;
    }

        .progress-info .muted {
            color: #666;
            font-weight: 400;
        }

    .progress-bar-outer {
        width: 100%;
        height: 10px;
        background: #e0e6ed;
        border-radius: 6px;
        overflow: hidden;
    }

    .progress-bar-inner {
        height: 100%;
        background: linear-gradient(90deg,#007bff,#3fa9ff);
        transition: width .35s ease;
    }

    .actions-inline {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        width: 100%;
    }

    .manual-grid {
        display: grid;
        gap: .6rem;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        align-items: end;
    }

    .manual-input {
        min-width: 0;
    }

    .upper-input {
        text-transform: uppercase;
    }


    .btn-success {
        background: #198754;
        color: #fff;
