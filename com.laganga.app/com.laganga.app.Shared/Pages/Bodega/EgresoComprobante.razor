@page "/Bodega/EgresoComprobante"
@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@implements IDisposable
@inject NavigationManager NavigationManager
@inject ParameterService ParamService
@inject IJSRuntime JSRuntime
@inject IHttpClientFactory HttpClientFactory

<h3 class="page-title">Egreso de Comprobantes</h3>


<!-- Encabezado fijo dentro del contenedor -->
<div class="top-header">
    <div class="filters">
        <div class="filters-row">
            <label class="section-title">Tipo</label>
            <DxRadioGroup Id="rdgrpTipoEgreso"
                          Items="@ItemsTipoEgreso"
                          TextFieldName="DisplayText"
                          ValueFieldName="IdValue"
                          Value="@PreferredTipoEgreso"
                          ValueChanged="@((string newValue) => OnPreferredTipoEgresoChanged(newValue))"
                          Layout="DevExpress.Blazor.RadioGroupLayout.Horizontal"
                          CssClass="dx-custom-radio-group"
                          aria-label="Tipo de Egreso"
                          SizeMode="SizeMode.Small" />
        </div>
    </div>

    <!-- Panel de Ingreso Manual -->
    <div class="manual-grid">
        <DxTextBox LabelText="@GetTipoName()"
                   @bind-Text="@selectedIdentificadorOrigen"
                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                   BindValueMode="BindValueMode.OnInput"
                   NullText="@($"Ingrese {GetTipoName()}")"
                   SizeMode="SizeMode.Small"
                   CssClass="manual-input" />
        @* filters-Identificador *@
        @if (PreferredTipoEgreso == "E")
        {
            <DxTextBox LabelText="Bodega"
                       @bind-Text="@selectedBodega"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       BindValueMode="BindValueMode.OnInput"
                       NullText="Ingrese Bodega"
                       SizeMode="SizeMode.Small"
                       CssClass="manual-input"
                       InputId="tbClearButton" />
        }

        <div class="manual-actions">
            <DxButton Text="Abrir"
                      Click="() => OnAbrirClick(selectedIdentificadorOrigen)"
                      ButtonType="ButtonType.Normal" />
        </div>
    </div>

    <!-- Buscador de ítems -->
    
</div>

<!-- Zona central que se desplaza -->
<div class="scroll-area">
    @if (isLoading)
    {
        <div class="status-block info">Cargando datos...</div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="status-block error">
            @loadError
            <DxButton Text="Reintentar"
                      ButtonType="ButtonType.Normal"
                      CssClass="retry-btn"
                      Click="LoadDataAsync" />
        </div>
    }
    else
    {

        <div class="filters-row">
            <DxTextBox LabelText="Buscar"
                       @bind-Text="searchText"
                       BindValueMode="BindValueMode.OnInput"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       NullText="Buscar por # visible o ID"
                       SizeMode="SizeMode.Small"
                       aria-label="Buscar secuencia"
                       CssClass="manual-input" />
        </div>

        <!-- Listado visual en 2 columnas, desplazamiento vertical -->
        <section class="items-section">
            @if (GridData?.Count == 0)
            {
                <div class="empty-hint">No hay elementos para mostrar.</div>
            }
            else if (FilteredGridData.Count == 0)
            {
                <div class="empty-hint">Sin coincidencias para "@searchText".</div>
            }
            else
            {
                <div class="items-grid" role="list" aria-label="Listado de secuencias">
                    @foreach (var it in FilteredGridData)
                    {
                        <div class="comp-card"
                             role="listitem"
                             tabindex="0"
                             title="@it.IdentificadorOrigenVisible"
                             @onclick="@(() => OnAbrirClick(it.IdentificadorOrigen))">
                            <div class="comp-row">
                                <div class="comp-num">#@it.IdentificadorOrigenVisible</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

@* <div class="footer-space"></div> *@


<!-- Popup Confirmación (overlay, no afecta el layout fijo) -->
<DxPopup @bind-Visible="showPopup"
         Position="PopupPosition.Center"
         ShowFooter="false"
         Width="340px"
         CloseOnOutsideClick="true">
    <HeaderTemplate>
        Toma Egresos Comprobantes - @GetTipoName()
    </HeaderTemplate>
    <BodyTemplate>
        <div>
            Esta seguro que desea tomar el egreso de comprobantes para la @GetTipoName():
            <strong>@selectedIdentificadorOrigenVisible</strong> ?
        </div>
        <div class="dialog-actions mt-2">
            <DxButton Text="Confirmar"
                      CssClass="finalize"
                      Click="@(() => AbrirSecuencia(selectedIdentificadorOrigen))" />
            <DxButton Text="Cerrar"
                      ButtonType="ButtonType.Normal"
                      Click="() => showPopup = false" />
        </div>
    </BodyTemplate>
</DxPopup>

<style>
    /* Layout base: ocupa toda la ventana y fija header/footer */


    .page-title {
        margin-bottom: .5rem;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .footer-space {
        height: 40px; /* permanece visible abajo */
        flex: 0 0 auto;
    }

    /* Estados */
    .status-block {
        padding: .75rem 1rem;
        border-radius: 6px;
        font-size: .9rem;
        display: flex;
        gap: .6rem;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        background: var(--dxbl-background, #fff);
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

        .status-block.info {
            background: #e8f4ff;
            color: #024c7b;
        }

        .status-block.error {
            background: #ffe8e8;
            color: #7b0202;
        }

    .retry-btn {
        background: #0d6efd10;
    }

    /* Header (siempre visible dentro del contenedor) */
    .top-header {
        z-index: 10;
        background: var(--dxbl-background, #fff);
        display: flex;
        flex-direction: column;
        gap: .75rem;
        padding: .6rem .75rem .9rem;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        border-radius: 8px;
        flex: 0 0 auto; /* no se estira */
    }

    .section-title {
        font-weight: 600;
        font-size: .9rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #2b4b70;
    }

    .filters .filters-row {
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .scroll-area .filters-row {
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
        padding: .55rem;
    }

    /* RadioGroup compacto */
    .dx-custom-radio-group {
        padding: .15rem 0 0 0;
    }

    /* Panel de ingreso manual */
    .manual-grid {
        display: grid;
        gap: .6rem;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        align-items: end;
    }

    .manual-input {
        min-width: 0;
    }

    .manual-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    /* Área central con scroll propio */
    .scroll-area {
        flex: 1 1 auto; /* ocupa todo el espacio disponible entre header y footer */
        min-height: 0; /* necesario para que overflow funcione dentro de flex */
        overflow: auto;
        -webkit-overflow-scrolling: touch;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        border-radius: 8px;
        max-height: 60%;
    }

    /* Listado vertical en 2 columnas */
    .items-section {
        background: var(--dxbl-background, #fff);
        padding: .55rem;
        min-height: 100%;
    }

    .items-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .6rem;
        align-items: stretch;
    }

    .empty-hint {
        padding: .65rem .8rem;
        color: #4a5568;
        font-size: .9rem;
    }

    .comp-card {
        border: 1px solid #e6e9ef;
        border-radius: 10px;
        padding: .55rem .6rem;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: .45rem;
        transition: border-color .2s ease, background-color .2s ease, transform .1s ease, box-shadow .2s ease;
        cursor: pointer;
        outline: none;
        min-height: 56px;
    }

        .comp-card:hover {
            transform: translateY(-1px);
            background: #f3f7fb;
            box-shadow: 0 2px 6px rgba(13,110,253,.08);
        }

        .comp-card:focus-visible {
            box-shadow: 0 0 0 2px rgba(13,110,253,.25);
            border-color: #0d6efd;
            background: #eef6ff;
        }

    .comp-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .4rem;
        min-width: 0;
    }

    .comp-num {
        font-weight: 700;
        color: #243b53;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .finalize {
        background: #198754;
        color: #fff;
    }

    .dialog-actions {
        display: flex;
        gap: .6rem;
        justify-content: flex-end;
        align-items: center;
    }

    /* Responsivo general */
    @@media (max-width: 640px) {
        .top-header {
            padding: .5rem .6rem .7rem;
        }

        .manual-grid {
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        }

            .manual-grid .filters-Identificador{
                width: 100px;
            }

        .items-grid {
            gap: .5rem;
        }

        .comp-card {
            padding: .5rem;
        }
    }

    /* Handheld 480x692 aprox: optimización crítica (mantener 2 columnas) */
    @@media (max-width: 520px) {
        .comp-num {
            font-size: .95rem;
        }

        .items-grid {
            gap: .5rem;
        }

        .comp-card {
            padding: .45rem;
            min-height: 48px;
        }

        .top-header {
            gap: .6rem;
        }
    }

    @@media (max-width: 520px) and (max-height: 740px) {
        .top-header {
            padding: .35rem .5rem .5rem;
            gap: .45rem;
        }

        .manual-grid {
            gap: .5rem;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }
        
        .top-header .manual-grid{
            grid-template-columns: 1fr auto;
            align-items: center;
        }

        .items-section {
            padding: .45rem;
        }

        .items-grid {
            gap: .45rem;
        }

        .scroll-area {
            max-height: 14rem;
            margin-top: 0.3rem;
        }
    }
</style>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "tipoPantalla")]
    public string? tipoPantalla { get; set; } = "";
    private string? _lastTipoPantalla;

    public bool datosCambiados { get; set; } = false;

    List<TipoEgresoItem> ItemsTipoEgreso { get; set; } = new();
    string PreferredTipoEgreso { get; set; } = string.Empty;

    List<OrigenMovimiento> GridData { get; set; } = new();
    DxGrid? Grid { get; set; }

    // Texto de búsqueda (filtra en vivo)
    string searchText { get; set; } = string.Empty;

    // Vista filtrada que se usa para renderizar
    IReadOnlyList<OrigenMovimiento> FilteredGridData =>
        string.IsNullOrWhiteSpace(searchText)
            ? GridData
            : GridData
                .Where(it =>
                    (!string.IsNullOrEmpty(it.IdentificadorOrigenVisible) &&
                     it.IdentificadorOrigenVisible.Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrEmpty(it.IdentificadorOrigen) &&
                     it.IdentificadorOrigen.Contains(searchText, StringComparison.OrdinalIgnoreCase)))
                .ToList();

    bool isLoading = false;
    string? loadError;

    CancellationTokenSource? _cts;
    IDisposable? _navReg;

    bool showPopup = false;
    string selectedIdentificadorOrigen = default!;
    string selectedIdentificadorOrigenVisible = default!;
    string selectedBodega = "000";

    protected override async Task OnInitializedAsync()
    {
        _navReg = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
        initParametros();

        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login", replace: true);
            return;
        }

        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(tipoPantalla))
            tipoPantalla = "OrigenBodega";

        if (_lastTipoPantalla == tipoPantalla)
            return;

        _lastTipoPantalla = tipoPantalla;
        initParametros();
        await LoadDataAsync();
    }

    string GetTipoName()
        => ItemsTipoEgreso.FirstOrDefault(p => p.IdValue == PreferredTipoEgreso)?.DisplayText ?? string.Empty;

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _navReg?.Dispose();
    }

    private void initParametros()
    {
        switch (tipoPantalla)
        {
            case "OrigenBodega":
                ItemsTipoEgreso = new()
                {
                    new() { DisplayText = "ID Cubicaje", IdValue = "C" },
                    new() { DisplayText = "ID HojaRuta", IdValue = "H" },
                    new() { DisplayText = "Compt. Egreso/Factura", IdValue = "E" }
                };
                break;
            case "OrigenSucursal":
                ItemsTipoEgreso = new()
                {
                    new() { DisplayText = "Compt. Egreso/Factura", IdValue = "E" }
                };
                break;
            default:
                ItemsTipoEgreso = new();
                break;
        }

        if (ItemsTipoEgreso.Count > 0)
            PreferredTipoEgreso = ItemsTipoEgreso[0].IdValue;
    }

    private async Task OnPreferredTipoEgresoChanged(string newValue)
    {
        PreferredTipoEgreso = newValue;
        // Limpiar el término de búsqueda al cambiar el tipo
        searchText = string.Empty;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loadError = null;
        isLoading = true;
        GridData.Clear();

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        try
        {
            if (!AuthService.IsAuthenticated)
            {
                loadError = "Sesión no autenticada.";
                NavigationManager.NavigateTo("/login", replace: true);
                return;
            }

            using var client = HttpClientFactory.CreateClient("Api");

            var options = new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            var apiResult = await client.GetFromJsonAsync<Result<List<OrigenMovimiento>>>(
                $"store/OrigenMovimientoMercaderia/{PreferredTipoEgreso}",
                options,
                ct);

            if (apiResult?.data is null)
            {
                loadError = "Respuesta sin datos.";
                return;
            }

            GridData = apiResult.data;
        }
        catch (OperationCanceledException)
        {
        }
        catch (HttpRequestException ex)
        {
            loadError = $"Error HTTP: {ex.Message}";
        }
        catch (System.Text.Json.JsonException ex)
        {
            loadError = $"Error parseando JSON: {ex.Message}";
        }
        catch (Exception ex)
        {
            loadError = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> AskBeforeLeavingAsync()
    {
        if (!datosCambiados) return false;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de que desea abandonar los cambios?");
        return !confirmed; // true => impedir navegación
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!await AskBeforeLeavingAsync()) return;
        context.PreventNavigation();
    }

    private void OnSecuenciaClick(GridRowClickEventArgs args)
    {
        if (Grid != null)
        {
            var dataItem = Grid.GetDataItem(args.VisibleIndex) as OrigenMovimiento;
            if (dataItem != null)
            {
                selectedIdentificadorOrigen = dataItem.IdentificadorOrigen.ToString();
                selectedIdentificadorOrigenVisible = dataItem.IdentificadorOrigenVisible;
            }
        }
    }

    void OnAbrirClick(string secuencia)
    {
        if (!string.IsNullOrEmpty(secuencia))
        {
            var item = GridData.FirstOrDefault(x => x.IdentificadorOrigen == secuencia);
            if (item != null)
            {
                selectedIdentificadorOrigen = secuencia;
                selectedIdentificadorOrigenVisible = item.IdentificadorOrigenVisible;
                showPopup = true;
            }
            else
            {
                selectedIdentificadorOrigen = secuencia;
                selectedIdentificadorOrigenVisible = secuencia;
                showPopup = true;
            }
        }
    }

    private async void AbrirSecuencia(string secuencia)
    {
        var guid = Guid.NewGuid().ToString();
        await SessionStorage.SetItemAsync($"{guid}-TipoEgreso", PreferredTipoEgreso);
        await SessionStorage.SetItemAsync($"{guid}-SelectedSecuencia", selectedIdentificadorOrigen);
        NavigationManager.NavigateTo($"/Bodega/EgresoComprobanteDetalle/{guid}", true, true);
    }

    public class TipoEgresoItem
    {
        public string DisplayText { get; set; } = string.Empty;
        public string IdValue { get; set; } = string.Empty;
    }
}