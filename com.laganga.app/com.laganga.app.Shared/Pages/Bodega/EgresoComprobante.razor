@page "/Bodega/EgresoComprobante"
@using com.laganga.app.Shared.Models
@using com.laganga.app.Shared.Services
@implements IDisposable
@inject NavigationManager Nav
@inject ParameterService ParamService
@inject IAuthenticationService AuthService
@inject IApiGangaClient apiClient
@inject IJSRuntime JS

<div class="title-bar">
    <h3 class="page-title">Egreso de Comprobantes</h3>

    <button type="button"
            class="@($"refresh-btn{(isLoading ? " spinning" : "")}")"
            @onclick="LoadDataAsync"
            disabled="@isLoading"
            aria-label="Actualizar"
            title="Actualizar">
        <svg class="refresh-icn" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12a9 9 0 1 1-2.64-6.36" />
            <polyline points="21 3 21 9 15 9" />
        </svg>
    </button>
</div>

<!-- Encabezado fijo dentro del contenedor -->
<div class="top-header">
    <div class="filters">
        <div class="filters-row">
            <label class="section-title">Tipo</label>
            <DxRadioGroup Id="rdgrpTipoEgreso"
                          Items="@ItemsTipoEgreso"
                          TextFieldName="DisplayText"
                          ValueFieldName="IdValue"
                          Value="@PreferredTipoEgreso"
                          ValueChanged="@((string newValue) => OnPreferredTipoEgresoChanged(newValue))"
                          Layout="DevExpress.Blazor.RadioGroupLayout.Horizontal"
                          CssClass="dx-custom-radio-group"
                          aria-label="Tipo de Egreso"
                          SizeMode="SizeMode.Small" />
        </div>
    </div>

    <!-- Panel de Ingreso Manual -->
    @if ((AuthService.CurrentUser?.FindFirst("control")?.Value ?? "no").Equals("total"))
    {
        <div class="manual-grid">
            <DxTextBox LabelText="@GetTipoName()"
                       @bind-Text="@selectedIdentificadorOrigen"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       BindValueMode="BindValueMode.OnInput"
                       NullText="@($"Ingrese {GetTipoName()}")"
                       SizeMode="SizeMode.Small"
                       CssClass="manual-input" />
            @* filters-Identificador *@
            

            <div class="manual-actions">
                <DxButton Text="Abrir"
                          Click="() => OnAbrirClick(selectedIdentificadorOrigen)"
                          ButtonType="ButtonType.Normal" />
            </div>
        </div>
    }


    @if (PreferredTipoEgreso == "E")
    {
        <div class="manual-grid">
            <DxTextBox LabelText="Bodega"
                       @bind-Text="@selectedBodega"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       BindValueMode="BindValueMode.OnInput"
                       NullText="Ingrese Bodega"
                       SizeMode="SizeMode.Small"
                       CssClass="manual-input"
                       InputId="tbClearButton" />
        </div>
    }

    <div class="manual-grid">
        <div class="filters-row">
            <DxTextBox LabelText="Buscar"
                       @bind-Text="searchText"
                       BindValueMode="BindValueMode.OnInput"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       NullText="Buscar por # visible o ID"
                       SizeMode="SizeMode.Small"
                       aria-label="Buscar secuencia"
                       CssClass="manual-input" />
        </div>
    </div>

    <!-- Buscador de ítems -->

</div>

<!-- Zona central que se desplaza -->
<div class="scroll-area">
    @if (isLoading)
    {
        <div class="status-block info">Cargando datos...</div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="status-block error">
            @loadError
            <DxButton Text="Reintentar"
                      ButtonType="ButtonType.Normal"
                      CssClass="retry-btn"
                      Click="LoadDataAsync" />
        </div>
    }
    else
    {

        

        <!-- Listado visual en 2 columnas, desplazamiento vertical -->
        <section class="items-section">
            @if (GridData?.Count == 0)
            {
                <div class="empty-hint">No hay elementos para mostrar.</div>
            }
            else if (FilteredGridData.Count == 0)
            {
                <div class="empty-hint">Sin coincidencias para "@searchText".</div>
            }
            else
            {
                <div class="items-grid" role="list" aria-label="Listado de secuencias">
                    @foreach (var it in FilteredGridData)
                    {
                        <div class="comp-card"
                             role="listitem"
                             tabindex="0"
                             title="@it.IdentificadorOrigenVisible"
                             @onclick="@(() => OnAbrirClick(it.IdentificadorOrigen))">
                            <div class="comp-row">
                                <div class="comp-num">#@it.IdentificadorOrigenVisible</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

@* Modal de confirmación (reemplaza DxPopup) *@
@if (showPopup)
{
    <div class="modal-backdrop" @onclick="() => showPopup = false">
        <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="egresoConfirmTitle" @onclick:stopPropagation>
            <div class="modal-header">
                <h4 id="egresoConfirmTitle" class="modal-title">Toma Egresos Comprobantes - @GetTipoName()</h4>
                <button type="button"
                        class="modal-close"
                        title="Cerrar"
                        aria-label="Cerrar"
                        @onclick="() => showPopup = false">
                    ×
                </button>
            </div>
            <div class="modal-body">
                <div>
                    Esta seguro que desea tomar el egreso de comprobantes para la @GetTipoName():
                    <strong>@selectedIdentificadorOrigenVisible</strong> ?
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" @onclick="() => showPopup = false">Cerrar</button>

                @if (!(selectedGuidId == null || selectedGuidId == Guid.Empty))
                {
                    <button class="btn btn-primary"
                            type="button"
                            @onclick="@(() => AbrirComprobanteDetalle(selectedGuidId))">
                        Continuar
                    </button>
                }

                <button class="btn btn-primary"
                        type="button"
                        @onclick="@(() => AbrirComprobanteDetalle())">
                    Nuevo
                </button>
            </div>
        </div>
    </div>
}



@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "tipoPantalla")]
    public string? tipoPantalla { get; set; } = "";
    private string? _lastTipoPantalla;
    private string DataOrigen { get { return "tipo_origen"; }}

    public bool datosCambiados { get; set; } = false;

    List<TipoEgresoItem> ItemsTipoEgreso { get; set; } = new();
    string PreferredTipoEgreso { get; set; } = string.Empty;

    List<OrigenMovimiento> GridData { get; set; } = new();
    DxGrid? Grid { get; set; }

    string searchText { get; set; } = string.Empty;

    IReadOnlyList<OrigenMovimiento> FilteredGridData =>
        string.IsNullOrWhiteSpace(searchText)
            ? GridData
            : GridData.Where(it =>
                (!string.IsNullOrEmpty(it.IdentificadorOrigenVisible) &&
                 it.IdentificadorOrigenVisible.Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(it.IdentificadorOrigen) &&
                 it.IdentificadorOrigen.Contains(searchText, StringComparison.OrdinalIgnoreCase)))
              .ToList();

    bool isLoading = false;
    string? loadError;

    CancellationTokenSource? _cts;
    IDisposable? _navReg;

    bool showPopup = false;
    string selectedIdentificadorOrigen = default!;
    string selectedIdentificadorOrigenVisible = default!;
    Guid? selectedGuidId = null;
    string selectedBodega = "000";

    private string selectedTipo = string.Empty;
    private bool isLoadingTipos;
    private string? errorTipos;
    private List<CustomAttributes> tiposPistoleo = new();

    protected override async Task OnInitializedAsync()
    {
        _navReg = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        AuthService.AuthenticationStateChanged += OnAuthChanged;
        initParametros();

        if (!AuthService.IsAuthenticated)
            return;

        await LoadDataAsync();
    }

    private void OnAuthChanged()
    {
        if (!AuthService.IsAuthenticated)
        {
            try { _cts?.Cancel(); } catch (ObjectDisposedException) { }
            _cts?.Dispose();
            _cts = null;
            isLoading = false;
            loadError = "Sesión expirada.";
            InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(tipoPantalla))
            tipoPantalla = "OrigenBodega";

        if (_lastTipoPantalla == tipoPantalla)
            return;

        _lastTipoPantalla = tipoPantalla;
        initParametros();
        await LoadDataAsync();
    }

    string GetTipoName()
        => ItemsTipoEgreso.FirstOrDefault(p => p.IdValue == PreferredTipoEgreso)?.DisplayText ?? string.Empty;

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthChanged;
        try { _cts?.Cancel(); } catch (ObjectDisposedException) { }
        _cts?.Dispose();
        _cts = null;
        _navReg?.Dispose();
    }

    private void initParametros()
    {
        if (_lastTipoPantalla is null) _lastTipoPantalla = tipoPantalla;
        switch (tipoPantalla)
        {
            case "OrigenBodega":
                ItemsTipoEgreso = new() {
                    new() { DisplayText = "ID Cubicaje", IdValue = "C" },
                    new() { DisplayText = "ID HojaRuta", IdValue = "H" },
                    new() { DisplayText = "Compt. Egreso/Factura", IdValue = "E" }
                };
                break;
            case "OrigenSucursal":
                ItemsTipoEgreso = new() {
                    new() { DisplayText = "Compt. Egreso/Factura", IdValue = "E" }
                };
                break;
            default:
                ItemsTipoEgreso = new();
                break;
        }

        if (ItemsTipoEgreso.Count > 0)
            PreferredTipoEgreso = ItemsTipoEgreso[0].IdValue;
    }

    private async Task OnPreferredTipoEgresoChanged(string newValue)
    {
        PreferredTipoEgreso = newValue;
        searchText = string.Empty;
        await LoadDataAsync();
    }

    private async Task CargarTiposPistoleoAsync()
    {
        errorTipos = null;

        try
        {
            isLoadingTipos = true;
            StateHasChanged();

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            var ct = _cts.Token;

            var urlrequest = $"v1/bodega/TipoHandHeld/{DataOrigen}";
            var response = await apiClient.GetAsync<List<CustomAttributes>>(urlrequest, ct);

            if (response?.succeeded ?? false)
            {
                tiposPistoleo = response.data ?? new();

                // Seleccionar el primer tipo por defecto si hay opciones
                if (tiposPistoleo.Count > 0 && string.IsNullOrEmpty(selectedTipo))
                {
                    selectedTipo = tiposPistoleo.First().Key;
                }
            }
            else
            {
                errorTipos = response?.message ?? "Error al cargar tipos de pistoleo.";
                tiposPistoleo = new();
            }
        }
        catch (OperationCanceledException)
        {
            // Ignorar cancelaciones
        }
        catch (Exception ex)
        {
            errorTipos = $"Error al cargar tipos: {ex.Message}";
            tiposPistoleo = new();
        }
        finally
        {
            isLoadingTipos = false;
            StateHasChanged();
        }
    }


    private async Task LoadDataAsync()
    {
        loadError = null;
        isLoading = true;
        GridData.Clear();

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        try
        {
            if (!AuthService.IsAuthenticated)
            {
                loadError = "Sesión no autenticada.";
                Nav.NavigateTo("/loginU", replace: true);
                return;
            }

            var urlRequest = $"v1/bodega/OrigenMovimientoMercaderia/{DataOrigen}/{PreferredTipoEgreso}";
            var response = await apiClient.GetAsync<List<OrigenMovimiento>>(urlRequest, ct);

            if ((response?.succeeded ?? false) == false)
            {
                loadError = response?.message ?? $"Error interno Seguimiento: {response?.message}";
                return;
            }

            if (response?.data is null)
            {
                loadError = "Respuesta sin datos.";
                return;
            }

            GridData = response.data;
        }
        catch (OperationCanceledException) { }
        catch (HttpRequestException ex)
        {
            loadError = $"Error HTTP: {ex.Message}";
        }
        catch (System.Text.Json.JsonException ex)
        {
            loadError = $"Error parseando JSON: {ex.Message}";
        }
        catch (Exception ex)
        {
            loadError = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> AskBeforeLeavingAsync()
    {
        if (!datosCambiados) return false;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de que desea abandonar los cambios?");
        return !confirmed;
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!await AskBeforeLeavingAsync()) return;
        context.PreventNavigation();
    }

    void OnAbrirClick(string IdentificadorOrigen)
    {
        if (!string.IsNullOrEmpty(IdentificadorOrigen))
        {
            var item = GridData.FirstOrDefault(x => x.IdentificadorOrigen == IdentificadorOrigen);
            if (item != null)
            {
                selectedIdentificadorOrigen = IdentificadorOrigen;
                selectedIdentificadorOrigenVisible = item.IdentificadorOrigenVisible;
                selectedGuidId = item.Guid;
                showPopup = true;
            }
            else
            {
                selectedIdentificadorOrigen = IdentificadorOrigen;
                selectedIdentificadorOrigenVisible = IdentificadorOrigen;
                selectedGuidId = null;
                showPopup = true;
            }
        }
    }

    private async void AbrirComprobanteDetalle(Guid? guid = null)
    {
        if (guid == null || guid == Guid.Empty) guid = Guid.NewGuid();

        await SessionStorage.SetItemAsync($"{guid}-TipoEgreso", PreferredTipoEgreso);
        await SessionStorage.SetItemAsync($"{guid}-SelectedSecuencia", selectedIdentificadorOrigen);
        Nav.NavigateTo($"/Bodega/EgresoComprobanteDetalle/{guid}", true, true);
    }

    public class TipoEgresoItem
    {
        public string DisplayText { get; set; } = string.Empty;
        public string IdValue { get; set; } = string.Empty;
    }
}




<style>
    /* Layout base: ocupa toda la ventana y fija header/footer */


    .page-title {
        margin-bottom: .5rem;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .footer-space {
        height: 40px; /* permanece visible abajo */
        flex: 0 0 auto;
    }

    /* Estados */
    .status-block {
        padding: .75rem 1rem;
        border-radius: 6px;
        font-size: .9rem;
        display: flex;
        gap: .6rem;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        background: var(--dxbl-background, #fff);
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

        .status-block.info {
            background: #e8f4ff;
            color: #024c7b;
        }

        .status-block.error {
            background: #ffe8e8;
            color: #7b0202;
        }

    .retry-btn {
        background: #0d6efd10;
    }

    /* Header (siempre visible dentro del contenedor) */
    .top-header {
        z-index: 10;
        background: var(--dxbl-background, #fff);
        display: flex;
        flex-direction: column;
        gap: .75rem;
        padding: .6rem .75rem .9rem;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        border-radius: 8px;
        flex: 0 0 auto; /* no se estira */
    }

    .section-title {
        font-weight: 600;
        font-size: .9rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #2b4b70;
    }

    .filters .filters-row {
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .scroll-area .filters-row {
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
        padding: .55rem;
    }

    /* RadioGroup compacto */
    .dx-custom-radio-group {
        padding: .15rem 0 0 0;
    }

    /* Panel de ingreso manual */
    .manual-grid {
        display: grid;
        gap: .6rem;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        align-items: end;
    }

    .manual-input {
        min-width: 0;
    }

    .manual-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    /* Área central con scroll propio */
    .scroll-area {
        flex: 1 1 auto; /* ocupa todo el espacio disponible entre header y footer */
        min-height: 0; /* necesario para que overflow funcione dentro de flex */
        overflow: auto;
        -webkit-overflow-scrolling: touch;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        border-radius: 8px;
        max-height: 60%;
    }

    /* Listado vertical en 2 columnas */
    .items-section {
        background: var(--dxbl-background, #fff);
        padding: .55rem;
        min-height: 100%;
    }

    .items-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .6rem;
        align-items: stretch;
    }

    .empty-hint {
        padding: .65rem .8rem;
        color: #4a5568;
        font-size: .9rem;
    }

    .comp-card {
        border: 1px solid #e6e9ef;
        border-radius: 10px;
        padding: .55rem .6rem;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: .45rem;
        transition: border-color .2s ease, background-color .2s ease, transform .1s ease, box-shadow .2s ease;
        cursor: pointer;
        outline: none;
        min-height: 56px;
    }

        .comp-card:hover {
            transform: translateY(-1px);
            background: #f3f7fb;
            box-shadow: 0 2px 6px rgba(13,110,253,.08);
        }

        .comp-card:focus-visible {
            box-shadow: 0 0 0 2px rgba(13,110,253,.25);
            border-color: #0d6efd;
            background: #eef6ff;
        }

    .comp-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .4rem;
        min-width: 0;
    }

    .comp-num {
        font-weight: 700;
        color: #243b53;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .finalize {
        background: #198754;
        color: #fff;
    }

    .dialog-actions {
        display: flex;
        gap: .6rem;
        justify-content: flex-end;
        align-items: center;
    }

    /* Modal simple y responsive (igual que Resumen) */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .modal-card {
        width: min(520px, 96vw);
        max-height: 92vh;
        background: #fff;
        color: #0f172a;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,.2);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .75rem 1rem;
        border-bottom: 1px solid #e6e9ef;
        background: #f8fafc;
    }

    .modal-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #1e293b;
    }

    .modal-close {
        border: none;
        background: transparent;
        font-size: 1.3rem;
        line-height: 1;
        cursor: pointer;
        color: #334155;
        width: 32px;
        height: 32px;
        border-radius: 6px;
    }

        .modal-close:hover {
            background: #eef2f7;
        }

    .modal-body {
        padding: .9rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .7rem;
        overflow: auto;
    }

    .modal-footer {
        padding: .75rem 1rem;
        border-top: 1px solid #e6e9ef;
        display: flex;
        justify-content: flex-end;
        gap: .5rem;
        background: #f8fafc;
    }

    .btn {
        padding: .45rem .8rem;
        border-radius: 6px;
        border: 1px solid #cfd6e4;
        background: #ffffff;
        color: #334155;
        cursor: pointer;
        font-size: .9rem;
    }

    .btn-primary {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
    }

    .btn-secondary:hover {
        background: #eef2f7;
    }

    .btn:disabled {
        opacity: .6;
        cursor: not-allowed;
    }

    .title-bar {
        position: relative;
    }

        .title-bar .page-title {
            margin-right: 44px; /* deja espacio para el botón */
        }

    .refresh-btn {
        position: absolute;
        top: 0;
        right: 0;
        width: 34px;
        height: 34px;
        border-radius: 6px;
        border: 1px solid #e6e9ef;
        background: var(--dxbl-background, #fff);
        color: #0d6efd;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color .15s ease, border-color .15s ease, transform .05s ease;
    }

        .refresh-btn:hover:not(:disabled) {
            background: #f0f6ff;
            border-color: #bcd6ff;
        }

        .refresh-btn:active:not(:disabled) {
            transform: translateY(1px);
        }

        .refresh-btn:disabled {
            opacity: .6;
            cursor: default;
        }

    .refresh-icn {
        width: 18px;
        height: 18px;
        display: block;
    }

    .refresh-btn.spinning .refresh-icn {
        animation: spin 1s linear infinite;
    }

    /* Responsivo general */
    @@media (max-width: 640px) {
        .top-header {
            padding: .5rem .6rem .7rem;
        }

        .manual-grid {
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        }

            .manual-grid .filters-Identificador {
                width: 100px;
            }

        .items-grid {
            gap: .5rem;
        }

        .comp-card {
            padding: .5rem;
        }
    }

    /* Handheld 480x692 aprox: optimización crítica (mantener 2 columnas) */
    @@media (max-width: 520px) {
        .comp-num {
            font-size: .95rem;
        }

        .items-grid {
            gap: .5rem;
        }

        .comp-card {
            padding: .45rem;
            min-height: 48px;
        }

        .top-header {
            gap: .6rem;
        }
    }

    @@media (max-width: 520px) and (max-height: 740px) {
        .top-header {
            padding: .35rem .5rem .5rem;
            gap: .45rem;
        }

        .manual-grid {
            gap: .5rem;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }

        .top-header .manual-grid {
            grid-template-columns: 1fr auto;
            align-items: center;
        }

        .items-section {
            padding: .45rem;
        }

        .items-grid {
            gap: .45rem;
        }

        .scroll-area {
            max-height: 14rem;
            margin-top: 0.3rem;
        }
    }
</style>