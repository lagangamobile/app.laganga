@inject com.laganga.app.Shared.Services.NetworkStatusService Net
@implements IDisposable

@if (!Net.IsOnline)
{
    <div class="conn-banner offline" role="alert">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="1" y1="1" x2="23" y2="23" />
            <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55" />
            <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39" />
            <path d="M10.71 5.05A16 16 0 0 1 22.56 9" />
            <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88" />
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0" />
            <line x1="12" y1="20" x2="12.01" y2="20" />
        </svg>
        Sin conexión a Internet.
    </div>
}
else if (!string.IsNullOrWhiteSpace(Net.LastApiErrorMessage))
{
    <div class="conn-banner degraded" role="alert">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        @Net.LastApiErrorMessage
    </div>
}

@code {
    protected override void OnInitialized() => Net.StatusChanged += OnChange;
    void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Net.StatusChanged -= OnChange;
}