@page "/"
@using com.laganga.app.Shared.Services
@inject IFormFactor FormFactor

<div class="home-root">
    <div class="home-header">
        <p class="welcome-label">Bienvenido</p>
        <h1 class="welcome-title">@((AuthService.CurrentUser?.FindFirst("given_name")?.Value + " " + AuthService.CurrentUser?.FindFirst("family_name")?.Value) ?? "")</h1>
    </div>

    <div class="home-actions">
        <div class="row g-3">
            <div class="col-6">
                <button type="button" class="action-tile">
                    <div class="action-icon">
                        <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
                            <path d="M3 11V3h8v8H3zm2-2h4V5H5v4zm-2 12v-8h8v8H3zm2-2h4v-4H5v4zm8-18h8v8h-8V3zm2 6h4V5h-4v4zm4 14h2v-6h-2v6zm-6-6h2v-2h-2v2zm2 2h2v-2h-2v2zm-2 2h2v-2h-2v2zm2 2h2v-2h-2v2zm2-2h2v-2h-2v2zm0-4h2v-2h-2v2zm2 2h2v-2h-2v2z" />
                        </svg>
                    </div>
                    <span class="action-label">Escanear</span>
                </button>
            </div>
            @* <div class="col-6">
                <button type="button" class="action-tile">
                    <div class="action-icon">
                        <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
                            <path d="M20 2H4c-1.1 0-2 .9-2 2v3c0 .55.45 1 1 1h1v11c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8h1c.55 0 1-.45 1-1V4c0-1.1-.9-2-2-2zm-5 12H9v-2h6v2zm5-7H4V4h16v3z" />
                        </svg>
                    </div>
                    <span class="action-label">Ingresos</span>
                </button>
            </div>
            <div class="col-6">
                <button type="button" class="action-tile">
